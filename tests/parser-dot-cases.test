@test("DOT: integer constant")
@given("file")
int main() {
    42;
}
@whenRun("./bin/cclynx", args="--emit-ast-dot")
@expectOutput("stdout")
digraph AST {
    node [shape=box, fontname="monospace"];
    n0 [label="TranslationUnit\n'{{any}}'"];
    n1 [label="FunctionDefinition\n'main' : int\nunspecified-parameters"];
    n2 [label="CompoundStatement"];
    n3 [label="ExpressionStatement"];
    n4 [label="IntegerConstant\n42 : int"];
    n3 -> n4;
    n2 -> n3;
    n1 -> n2;
    n0 -> n1;
}

@endtest

@test("DOT: float constant")
@given("file")
int main() {
    3.14;
}
@whenRun("./bin/cclynx", args="--emit-ast-dot")
@expectOutput("stdout")
digraph AST {
    node [shape=box, fontname="monospace"];
    n0 [label="TranslationUnit\n'{{any}}'"];
    n1 [label="FunctionDefinition\n'main' : int\nunspecified-parameters"];
    n2 [label="CompoundStatement"];
    n3 [label="ExpressionStatement"];
    n4 [label="FloatConstant\n3.140000 : float"];
    n3 -> n4;
    n2 -> n3;
    n1 -> n2;
    n0 -> n1;
}

@endtest

@test("DOT: variable declaration, assignment, and reference")
@given("file")
int main() {
    int x;
    x = 5;
    return x;
}
@whenRun("./bin/cclynx", args="--emit-ast-dot")
@expectOutput("stdout")
digraph AST {
    node [shape=box, fontname="monospace"];
    n0 [label="TranslationUnit\n'{{any}}'"];
    n1 [label="FunctionDefinition\n'main' : int\nunspecified-parameters"];
    n2 [label="CompoundStatement"];
    n3 [label="VariableDeclaration\n'x' : int"];
    n2 -> n3;
    n4 [label="ExpressionStatement"];
    n5 [label="AssignmentExpression '='"];
    n6 [label="Variable\n'x' : int"];
    n5 -> n6 [label="lhs"];
    n7 [label="IntegerConstant\n5 : int"];
    n5 -> n7 [label="rhs"];
    n4 -> n5;
    n2 -> n4;
    n8 [label="ReturnStatement"];
    n9 [label="Variable\n'x' : int"];
    n8 -> n9;
    n2 -> n8;
    n1 -> n2;
    n0 -> n1;
}

@endtest

@test("DOT: additive expression")
@given("file")
int main() {
    return 2 + 3;
}
@whenRun("./bin/cclynx", args="--emit-ast-dot")
@expectOutput("stdout")
digraph AST {
    node [shape=box, fontname="monospace"];
    n0 [label="TranslationUnit\n'{{any}}'"];
    n1 [label="FunctionDefinition\n'main' : int\nunspecified-parameters"];
    n2 [label="CompoundStatement"];
    n3 [label="ReturnStatement"];
    n4 [label="AdditiveExpression '+'\n: int"];
    n5 [label="IntegerConstant\n2 : int"];
    n4 -> n5 [label="lhs"];
    n6 [label="IntegerConstant\n3 : int"];
    n4 -> n6 [label="rhs"];
    n3 -> n4;
    n2 -> n3;
    n1 -> n2;
    n0 -> n1;
}

@endtest

