@test("DOT: equality expression")
@given("file")
int main() {
    return 2 == 3;
}
@whenRun("./bin/cclynx", args="--emit-ast-dot")
@expectOutput("stdout")
digraph AST {
    node [shape=box, fontname="monospace"];
    n0 [label="TranslationUnit\n'{{any}}'"];
    n1 [label="FunctionDefinition\n'main' : int\nunspecified-parameters"];
    n2 [label="CompoundStatement"];
    n3 [label="ReturnStatement"];
    n4 [label="EqualityExpression '=='\n: int"];
    n5 [label="IntegerConstant\n2 : int"];
    n4 -> n5 [label="lhs"];
    n6 [label="IntegerConstant\n3 : int"];
    n4 -> n6 [label="rhs"];
    n3 -> n4;
    n2 -> n3;
    n1 -> n2;
    n0 -> n1;
}

@endtest

@test("DOT: if-else statement")
@given("file")
int main() {
    int x;
    x = 1;
    if (x == 1) {
        x = 2;
    } else {
        x = 3;
    }
    return x;
}
@whenRun("./bin/cclynx", args="--emit-ast-dot")
@expectOutput("stdout")
digraph AST {
    node [shape=box, fontname="monospace"];
    n0 [label="TranslationUnit\n'{{any}}'"];
    n1 [label="FunctionDefinition\n'main' : int\nunspecified-parameters"];
    n2 [label="CompoundStatement"];
    n3 [label="VariableDeclaration\n'x' : int"];
    n2 -> n3;
    n4 [label="ExpressionStatement"];
    n5 [label="AssignmentExpression '='"];
    n6 [label="Variable\n'x' : int"];
    n5 -> n6 [label="lhs"];
    n7 [label="IntegerConstant\n1 : int"];
    n5 -> n7 [label="rhs"];
    n4 -> n5;
    n2 -> n4;
    n8 [label="IfStatement"];
    n9 [label="EqualityExpression '=='\n: int"];
    n10 [label="Variable\n'x' : int"];
    n9 -> n10 [label="lhs"];
    n11 [label="IntegerConstant\n1 : int"];
    n9 -> n11 [label="rhs"];
    n8 -> n9 [label="condition"];
    n12 [label="CompoundStatement"];
    n13 [label="ExpressionStatement"];
    n14 [label="AssignmentExpression '='"];
    n15 [label="Variable\n'x' : int"];
    n14 -> n15 [label="lhs"];
    n16 [label="IntegerConstant\n2 : int"];
    n14 -> n16 [label="rhs"];
    n13 -> n14;
    n12 -> n13;
    n8 -> n12 [label="true"];
    n17 [label="CompoundStatement"];
    n18 [label="ExpressionStatement"];
    n19 [label="AssignmentExpression '='"];
    n20 [label="Variable\n'x' : int"];
    n19 -> n20 [label="lhs"];
    n21 [label="IntegerConstant\n3 : int"];
    n19 -> n21 [label="rhs"];
    n18 -> n19;
    n17 -> n18;
    n8 -> n17 [label="false"];
    n2 -> n8;
    n22 [label="ReturnStatement"];
    n23 [label="Variable\n'x' : int"];
    n22 -> n23;
    n2 -> n22;
    n1 -> n2;
    n0 -> n1;
}

@endtest

@test("DOT: while statement")
@given("file")
int main() {
    int i;
    i = 0;
    while (i < 3) {
        i = i + 1;
    }
    return i;
}
@whenRun("./bin/cclynx", args="--emit-ast-dot")
@expectOutput("stdout")
digraph AST {
    node [shape=box, fontname="monospace"];
    n0 [label="TranslationUnit\n'{{any}}'"];
    n1 [label="FunctionDefinition\n'main' : int\nunspecified-parameters"];
    n2 [label="CompoundStatement"];
    n3 [label="VariableDeclaration\n'i' : int"];
    n2 -> n3;
    n4 [label="ExpressionStatement"];
    n5 [label="AssignmentExpression '='"];
    n6 [label="Variable\n'i' : int"];
    n5 -> n6 [label="lhs"];
    n7 [label="IntegerConstant\n0 : int"];
    n5 -> n7 [label="rhs"];
    n4 -> n5;
    n2 -> n4;
    n8 [label="WhileStatement"];
    n9 [label="RelationalExpression '<'\n: int"];
    n10 [label="Variable\n'i' : int"];
    n9 -> n10 [label="lhs"];
    n11 [label="IntegerConstant\n3 : int"];
    n9 -> n11 [label="rhs"];
    n8 -> n9 [label="condition"];
    n12 [label="CompoundStatement"];
    n13 [label="ExpressionStatement"];
    n14 [label="AssignmentExpression '='"];
    n15 [label="Variable\n'i' : int"];
    n14 -> n15 [label="lhs"];
    n16 [label="AdditiveExpression '+'\n: int"];
    n17 [label="Variable\n'i' : int"];
    n16 -> n17 [label="lhs"];
    n18 [label="IntegerConstant\n1 : int"];
    n16 -> n18 [label="rhs"];
    n14 -> n16 [label="rhs"];
    n13 -> n14;
    n12 -> n13;
    n8 -> n12 [label="body"];
    n2 -> n8;
    n19 [label="ReturnStatement"];
    n20 [label="Variable\n'i' : int"];
    n19 -> n20;
    n2 -> n19;
    n1 -> n2;
    n0 -> n1;
}

@endtest

@test("DOT: cast expression")
@given("file")
int main() {
    return (int)3.14;
}
@whenRun("./bin/cclynx", args="--emit-ast-dot")
@expectOutput("stdout")
digraph AST {
    node [shape=box, fontname="monospace"];
    n0 [label="TranslationUnit\n'{{any}}'"];
    n1 [label="FunctionDefinition\n'main' : int\nunspecified-parameters"];
    n2 [label="CompoundStatement"];
    n3 [label="ReturnStatement"];
    n4 [label="CastExpression\n: int"];
    n5 [label="FloatConstant\n3.140000 : float"];
    n4 -> n5;
    n3 -> n4;
    n2 -> n3;
    n1 -> n2;
    n0 -> n1;
}

@endtest

@test("DOT: bare return statement")
@given("file")
int main() {
    return;
}
@whenRun("./bin/cclynx", args="--emit-ast-dot")
@expectOutput("stdout")
digraph AST {
    node [shape=box, fontname="monospace"];
    n0 [label="TranslationUnit\n'{{any}}'"];
    n1 [label="FunctionDefinition\n'main' : int\nunspecified-parameters"];
    n2 [label="CompoundStatement"];
    n3 [label="ReturnStatement"];
    n2 -> n3;
    n1 -> n2;
    n0 -> n1;
}

@endtest
