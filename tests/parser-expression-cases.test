@test("It should parse an integer constant")
@given("file", filename="expr_1.c")
int main() {
    777;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: 'expr_1.c'
|
+-> FunctionDefinition: 'main' {type: 'int'} <unspecified-parameters>
    |
    +-> CompoundStatement
        |
        +-> ExpressionStatement
            |
            +-> IntegerConstant: '777' {type: 'int'}

@endtest

@test("It should parse a float constant")
