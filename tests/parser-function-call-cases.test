@test("It should parse function calls without parameters")
@given("file")
int foo(void) {
   return 7;
}

int main() {
    return 42 * foo();
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
|
+-> FunctionDefinition: 'foo' {type: 'int'} <no-parameters>
|   |
|   +-> CompoundStatement
|       |
|       +-> ReturnStatement
|           |
|           +-> IntegerConstant: '7' {type: 'int'}
|
+-> FunctionDefinition: 'main' {type: 'int'} <unspecified-parameters>
    |
    +-> CompoundStatement
        |
        +-> ReturnStatement
            |
            +-> MultiplicativeExpression: '*' {type: 'int'}
                |
                +-> IntegerConstant: '42' {type: 'int'}
                |
                +-> FunctionCallExpression: 'foo' {type: 'int'} <no-arguments>

@endtest

@test("It should parse function calls with unspecified parameters")
@given("file")
int foo() {
   return 7;
}

int main() {
    return 42 * foo();
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
|
+-> FunctionDefinition: 'foo' {type: 'int'} <unspecified-parameters>
|   |
|   +-> CompoundStatement
|       |
|       +-> ReturnStatement
|           |
|           +-> IntegerConstant: '7' {type: 'int'}
|
+-> FunctionDefinition: 'main' {type: 'int'} <unspecified-parameters>
    |
    +-> CompoundStatement
        |
        +-> ReturnStatement
            |
            +-> MultiplicativeExpression: '*' {type: 'int'}
                |
                +-> IntegerConstant: '42' {type: 'int'}
                |
                +-> FunctionCallExpression: 'foo' {type: 'int'} <no-arguments>

@endtest


@test("It should parse function call with unspecified parameters and arguments provided")
@given("file")
int foo() {
   return 7;
}

int main() {
    return foo(42);
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
|
+-> FunctionDefinition: 'foo' {type: 'int'} <unspecified-parameters>
|   |
|   +-> CompoundStatement
|       |
|       +-> ReturnStatement
|           |
|           +-> IntegerConstant: '7' {type: 'int'}
|
+-> FunctionDefinition: 'main' {type: 'int'} <unspecified-parameters>
    |
    +-> CompoundStatement
        |
        +-> ReturnStatement
            |
            +-> FunctionCallExpression: 'foo' {type: 'int'} <1-argument>
                |
                +-> IntegerConstant: '42' {type: 'int'}

@endtest

@test("It should parse function call with 1 argument")
@given("file")
int identity(int a) {
    return a;
}

int main() {
    return identity(42);
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
|
+-> FunctionDefinition: 'identity' {type: 'int'} <1-parameter>
|   |
|   +-> ParameterList
|   |   |
|   |   +-> Parameter: 'a' {type: 'int'}
|   |
|   +-> CompoundStatement
|       |
|       +-> ReturnStatement
|           |
|           +-> VariableExpression: 'a' {type: 'int'}
|
+-> FunctionDefinition: 'main' {type: 'int'} <unspecified-parameters>
    |
    +-> CompoundStatement
        |
        +-> ReturnStatement
            |
            +-> FunctionCallExpression: 'identity' {type: 'int'} <1-argument>
                |
                +-> IntegerConstant: '42' {type: 'int'}

@endtest

@test("It should parse function call with 2 arguments")
@given("file")
int add(int a, int b) {
    return a + b;
}

int main() {
    return add(19, 23);
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
|
+-> FunctionDefinition: 'add' {type: 'int'} <2-parameters>
|   |
|   +-> ParameterList
|   |   |
|   |   +-> Parameter: 'a' {type: 'int'}
|   |   |
|   |   +-> Parameter: 'b' {type: 'int'}
|   |
|   +-> CompoundStatement
|       |
|       +-> ReturnStatement
|           |
|           +-> AdditiveExpression: '+' {type: 'int'}
|               |
|               +-> VariableExpression: 'a' {type: 'int'}
|               |
|               +-> VariableExpression: 'b' {type: 'int'}
|
+-> FunctionDefinition: 'main' {type: 'int'} <unspecified-parameters>
    |
    +-> CompoundStatement
        |
        +-> ReturnStatement
            |
            +-> FunctionCallExpression: 'add' {type: 'int'} <2-arguments>
                |
                +-> IntegerConstant: '19' {type: 'int'}
                |
                +-> IntegerConstant: '23' {type: 'int'}

@endtest

@test("It should parse function call with 3 arguments")
@given("file")
int foo(int a, int b, int c) {
    return a + b * c;
}

int main() {
    return foo(1, 2, 3);
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
|
+-> FunctionDefinition: 'foo' {type: 'int'} <3-parameters>
|   |
|   +-> ParameterList
|   |   |
|   |   +-> Parameter: 'a' {type: 'int'}
|   |   |
|   |   +-> Parameter: 'b' {type: 'int'}
|   |   |
|   |   +-> Parameter: 'c' {type: 'int'}
|   |
|   +-> CompoundStatement
|       |
|       +-> ReturnStatement
|           |
|           +-> AdditiveExpression: '+' {type: 'int'}
|               |
|               +-> VariableExpression: 'a' {type: 'int'}
|               |
|               +-> MultiplicativeExpression: '*' {type: 'int'}
|                   |
|                   +-> VariableExpression: 'b' {type: 'int'}
|                   |
|                   +-> VariableExpression: 'c' {type: 'int'}
|
+-> FunctionDefinition: 'main' {type: 'int'} <unspecified-parameters>
    |
    +-> CompoundStatement
        |
        +-> ReturnStatement
            |
            +-> FunctionCallExpression: 'foo' {type: 'int'} <3-arguments>
                |
                +-> IntegerConstant: '1' {type: 'int'}
                |
                +-> IntegerConstant: '2' {type: 'int'}
                |
                +-> IntegerConstant: '3' {type: 'int'}

@endtest

@test("It should parse function call with expression arguments")
@given("file")
int add(int a, int b) {
    return a + b;
}

int main() {
    return add(1 + 2, 3 * 4);
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
|
+-> FunctionDefinition: 'add' {type: 'int'} <2-parameters>
|   |
|   +-> ParameterList
|   |   |
|   |   +-> Parameter: 'a' {type: 'int'}
|   |   |
|   |   +-> Parameter: 'b' {type: 'int'}
|   |
|   +-> CompoundStatement
|       |
|       +-> ReturnStatement
|           |
|           +-> AdditiveExpression: '+' {type: 'int'}
|               |
|               +-> VariableExpression: 'a' {type: 'int'}
|               |
|               +-> VariableExpression: 'b' {type: 'int'}
|
+-> FunctionDefinition: 'main' {type: 'int'} <unspecified-parameters>
    |
    +-> CompoundStatement
        |
        +-> ReturnStatement
            |
            +-> FunctionCallExpression: 'add' {type: 'int'} <2-arguments>
                |
                +-> AdditiveExpression: '+' {type: 'int'}
                |   |
                |   +-> IntegerConstant: '1' {type: 'int'}
                |   |
                |   +-> IntegerConstant: '2' {type: 'int'}
                |
                +-> MultiplicativeExpression: '*' {type: 'int'}
                    |
                    +-> IntegerConstant: '3' {type: 'int'}
                    |
                    +-> IntegerConstant: '4' {type: 'int'}

@endtest

@test("It should raise an error on argument count mismatch")
@given("file")
int add(int a, int b) {
    return a + b;
}

int main() {
    return add(1);
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stderr")
ERROR: function 'add' expects 2 arguments but 1 were provided

@endtest

@test("It should raise an error on argument type mismatch")
@given("file")
int identity(int a) {
    return a;
}

int main() {
    return identity((float) 1);
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stderr")
ERROR: argument 1 of function 'identity' has type 'float' but expected 'int'

@endtest

@test("It should raise an error when function call uses a keyword as name")
@given("file")
int main() {
    return 42 * while();
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stderr")
ERROR: expected identifier but not a keyword!

@endtest
