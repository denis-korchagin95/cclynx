@test("It should generate OP_UNSIGNED_DIV for unsigned int division")
@given("file")
unsigned int main() {
    unsigned int x;
    x = 10u;
    return x / 3u;
}
@whenRun("./bin/cclynx", args="--emit-ir --no-warnings")
@expectOutput("stdout")
OP_FUNC "main"
OP_CONST 10, t1
OP_STORE x, t1
OP_LOAD x, t2
OP_CONST 3, t3
OP_UNSIGNED_DIV t2, t3, t4
OP_RETURN t4
OP_FUNC_END

@endtest

@test("It should generate OP_DIV for signed int division")
@given("file")
int main() {
    int x;
    x = 10;
    return x / 3;
}
@whenRun("./bin/cclynx", args="--emit-ir --no-warnings")
@expectOutput("stdout")
OP_FUNC "main"
OP_CONST 10, t1
OP_STORE x, t1
OP_LOAD x, t2
OP_CONST 3, t3
OP_DIV t2, t3, t4
OP_RETURN t4
OP_FUNC_END

@endtest

@test("It should generate OP_UNSIGNED_LT for unsigned less than")
@given("file")
int main() {
    unsigned int a;
    a = 3u;
    unsigned int b;
    b = 5u;
    int r;
    r = a < b;
    return r;
}
@whenRun("./bin/cclynx", args="--emit-ir --no-warnings")
@expectOutput("stdout")
OP_FUNC "main"
OP_CONST 3, t1
OP_STORE a, t1
OP_CONST 5, t2
OP_STORE b, t2
OP_LOAD a, t3
OP_LOAD b, t4
OP_UNSIGNED_LT t3, t4, t5
OP_STORE r, t5
OP_LOAD r, t6
OP_RETURN t6
OP_FUNC_END

@endtest

@test("It should generate OP_UNSIGNED_GT for unsigned greater than")
@given("file")
int main() {
    unsigned int a;
    a = 5u;
    unsigned int b;
    b = 3u;
    int r;
    r = a > b;
    return r;
}
@whenRun("./bin/cclynx", args="--emit-ir --no-warnings")
@expectOutput("stdout")
OP_FUNC "main"
OP_CONST 5, t1
OP_STORE a, t1
OP_CONST 3, t2
OP_STORE b, t2
OP_LOAD a, t3
OP_LOAD b, t4
OP_UNSIGNED_GT t3, t4, t5
OP_STORE r, t5
OP_LOAD r, t6
OP_RETURN t6
OP_FUNC_END

@endtest
