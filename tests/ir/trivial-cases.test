@test("It should generate IR code on bare return statement")
@given("file")
int main() {
    return;
}
@whenRun("./bin/cclynx", args="--emit-ir")
@expectOutput("stdout")
OP_FUNC "main"
OP_RETURN
OP_FUNC_END

@endtest

@test("It should generate IR code on return large integer constant")
@given("file")
int main() {
    return 100000;
}
@whenRun("./bin/cclynx", args="--emit-ir")
@expectOutput("stdout")
OP_FUNC "main"
OP_CONST 100000, t1
OP_RETURN t1
OP_FUNC_END

@endtest

@test("It should generate IR code on return integer constant")
@given("file")
int main() {
    return 7;
}
@whenRun("./bin/cclynx", args="--emit-ir")
@expectOutput("stdout")
OP_FUNC "main"
OP_CONST 7, t1
OP_RETURN t1
OP_FUNC_END

@endtest

@test("It should generate IR code on return trivial expression (without variables +, *)")
@given("file")
int main() {
    return 2 * 3 + 1;
}
@whenRun("./bin/cclynx", args="--emit-ir")
@expectOutput("stdout")
OP_FUNC "main"
OP_CONST 2, t1
OP_CONST 3, t2
OP_MUL t1, t2, t3
OP_CONST 1, t4
OP_ADD t3, t4, t5
OP_RETURN t5
OP_FUNC_END

@endtest

@test("It should generate IR code on return trivial expression with nested sub-expressions")
@given("file")
int main() {
    return 2 * ((3 * 4 + 20) + 1) * 15;
}
@whenRun("./bin/cclynx", args="--emit-ir")
@expectOutput("stdout")
OP_FUNC "main"
OP_CONST 2, t1
OP_CONST 3, t2
OP_CONST 4, t3
OP_MUL t2, t3, t4
OP_CONST 20, t5
OP_ADD t4, t5, t6
OP_CONST 1, t7
OP_ADD t6, t7, t8
OP_MUL t1, t8, t9
OP_CONST 15, t10
OP_MUL t9, t10, t11
OP_RETURN t11
OP_FUNC_END

@endtest

@test("It should generate IR code on return trivial expression (without variables, -, /)")
@given("file")
int main() {
    return 12 / 3 - 1;
}
@whenRun("./bin/cclynx", args="--emit-ir")
@expectOutput("stdout")
OP_FUNC "main"
OP_CONST 12, t1
OP_CONST 3, t2
OP_DIV t1, t2, t3
OP_CONST 1, t4
OP_SUB t3, t4, t5
OP_RETURN t5
OP_FUNC_END

@endtest

@test("It should generate IR code on return trivial expression (without variables, >)")
@given("file")
int main() {
    return 12 > 3;
}
@whenRun("./bin/cclynx", args="--emit-ir")
@expectOutput("stdout")
OP_FUNC "main"
OP_CONST 12, t1
OP_CONST 3, t2
OP_GT t1, t2, t3
OP_RETURN t3
OP_FUNC_END

@endtest

@test("It should generate IR code on return trivial expression (without variables, <)")
