@test("It should generate IR code on while loop statement with expression <")
@given("file")
int main() {
    int i;
    i = 0;
    while (i < 10) {
        i = i + 1;
    }
    return i * 7 + 7;
}
@whenRun("./bin/cclynx", args="--emit-ir")
@expectOutput("stdout")
OP_FUNC "main"
OP_CONST 0, t1
OP_STORE i, t1
OP_LABEL ".L1"
OP_LOAD i, t2
OP_CONST 10, t3
OP_JUMP_IF_GREATER_THAN_OR_EQUAL t2, t3, ".L2"
OP_LOAD i, t4
OP_CONST 1, t5
OP_ADD t4, t5, t6
OP_STORE i, t6
OP_JUMP ".L1"
OP_LABEL ".L2"
OP_LOAD i, t7
OP_CONST 7, t8
OP_MUL t7, t8, t9
OP_CONST 7, t10
OP_ADD t9, t10, t11
OP_RETURN t11
OP_FUNC_END

@endtest

@test("It should generate IR code on while loop statement with expression >")
@given("file")
int main() {
    int i;
    i = 20;
    while (i > 10) {
        i = i - 1;
    }
    return i * 7 + 7;
}
@whenRun("./bin/cclynx", args="--emit-ir")
@expectOutput("stdout")
OP_FUNC "main"
OP_CONST 20, t1
OP_STORE i, t1
OP_LABEL ".L1"
OP_LOAD i, t2
OP_CONST 10, t3
OP_JUMP_IF_LESS_THAN_OR_EQUAL t2, t3, ".L2"
OP_LOAD i, t4
OP_CONST 1, t5
OP_SUB t4, t5, t6
OP_STORE i, t6
OP_JUMP ".L1"
OP_LABEL ".L2"
OP_LOAD i, t7
OP_CONST 7, t8
OP_MUL t7, t8, t9
OP_CONST 7, t10
OP_ADD t9, t10, t11
OP_RETURN t11
OP_FUNC_END

@endtest

@test("It should generate IR code on while loop statement with expression ==")
@given("file")
int main() {
    int i;
    i = 0;
    while (i == 0) {
        i = i + 7;
    }
    return i;
}
@whenRun("./bin/cclynx", args="--emit-ir")
@expectOutput("stdout")
OP_FUNC "main"
OP_CONST 0, t1
OP_STORE i, t1
OP_LABEL ".L1"
OP_LOAD i, t2
OP_CONST 0, t3
OP_JUMP_IF_NOT_EQUAL t2, t3, ".L2"
OP_LOAD i, t4
OP_CONST 7, t5
OP_ADD t4, t5, t6
OP_STORE i, t6
OP_JUMP ".L1"
OP_LABEL ".L2"
OP_LOAD i, t7
OP_RETURN t7
OP_FUNC_END

@endtest

@test("It should generate IR code on while loop statement with expression !=")
@given("file")
int main() {
    int i;
    i = 10;
    while (i != 3) {
        i = i - 1;
    }
    return i;
}
@whenRun("./bin/cclynx", args="--emit-ir")
@expectOutput("stdout")
OP_FUNC "main"
OP_CONST 10, t1
OP_STORE i, t1
OP_LABEL ".L1"
OP_LOAD i, t2
OP_CONST 3, t3
OP_JUMP_IF_EQUAL t2, t3, ".L2"
OP_LOAD i, t4
OP_CONST 1, t5
OP_SUB t4, t5, t6
OP_STORE i, t6
OP_JUMP ".L1"
OP_LABEL ".L2"
OP_LOAD i, t7
OP_RETURN t7
OP_FUNC_END

@endtest

@test("It should generate IR code on while loop statement with constant false condition")
@given("file")
int main() {
    int i;
    i = 1;
    while (0) {
        i = i + 1;
    }
    return i;
}
@whenRun("./bin/cclynx", args="--emit-ir")
@expectOutput("stdout")
OP_FUNC "main"
OP_CONST 1, t1
OP_STORE i, t1
OP_LABEL ".L1"
OP_CONST 0, t2
OP_JUMP_IF_FALSE t2, ".L2"
OP_LOAD i, t3
OP_CONST 1, t4
OP_ADD t3, t4, t5
OP_STORE i, t5
OP_JUMP ".L1"
OP_LABEL ".L2"
OP_LOAD i, t6
OP_RETURN t6
OP_FUNC_END

@endtest

@test("It should generate IR code on while loop statement with constant true condition")
@given("file")
int main() {
    int i;
    i = 1;
    while (1) {
        i = i + 1;
    }
    return i;
}
@whenRun("./bin/cclynx", args="--emit-ir")
@expectOutput("stdout")
OP_FUNC "main"
OP_CONST 1, t1
OP_STORE i, t1
OP_LABEL ".L1"
OP_CONST 1, t2
OP_JUMP_IF_FALSE t2, ".L2"
OP_LOAD i, t3
OP_CONST 1, t4
OP_ADD t3, t4, t5
OP_STORE i, t5
OP_JUMP ".L1"
OP_LABEL ".L2"
OP_LOAD i, t6
OP_RETURN t6
OP_FUNC_END

@endtest

@test("It should generate IR code on while loop with empty expression statement")
@given("file")
int main() {
    while (0);
    return 0;
}
@whenRun("./bin/cclynx", args="--emit-ir")
@expectOutput("stdout")
OP_FUNC "main"
OP_LABEL ".L1"
OP_CONST 0, t1
OP_JUMP_IF_FALSE t1, ".L2"
OP_NOP
OP_JUMP ".L1"
OP_LABEL ".L2"
OP_CONST 0, t2
OP_RETURN t2
OP_FUNC_END

@endtest

@test("It should generate IR code on while loop with empty compound statement")
@given("file")
int main() {
    while (0) {
    }
    return 0;
}
@whenRun("./bin/cclynx", args="--emit-ir")
@expectOutput("stdout")
OP_FUNC "main"
OP_LABEL ".L1"
OP_CONST 0, t1
OP_JUMP_IF_FALSE t1, ".L2"
OP_NOP
OP_JUMP ".L1"
OP_LABEL ".L2"
OP_CONST 0, t2
OP_RETURN t2
OP_FUNC_END

@endtest

@test("It should generate IR code for while loop with float condition")
@given("file")
int main() {
    float n;
    n = 10.0;
    while (n > 5.0) {
        n = n - 1.0;
    }
    return (int)n;
}
@whenRun("./bin/cclynx", args="--emit-ir")
@expectOutput("stdout")
OP_FUNC "main"
OP_CONST 10.000000, t1
OP_STORE n, t1
OP_LABEL ".L1"
OP_LOAD n, t2
OP_CONST 5.000000, t3
OP_JUMP_IF_LESS_THAN_OR_EQUAL t2, t3, ".L2"
OP_LOAD n, t4
OP_CONST 1.000000, t5
OP_SUB t4, t5, t6
OP_STORE n, t6
OP_JUMP ".L1"
OP_LABEL ".L2"
OP_LOAD n, t7
OP_INT_CAST t7, t8
OP_RETURN t8
OP_FUNC_END

@endtest
