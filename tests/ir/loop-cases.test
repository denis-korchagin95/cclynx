@test("It should generate IR code on while loop statement with expression <")
@given("stdin")
int main() {
    int i;
    i = 0;
    while (i < 10) {
        i = i + 1;
    }
    return i * 7 + 7;
}
@whenRun("./bin/cclynx", args="--emit-ir /dev/stdin")
@expectOutput("stdout")
OP_FUNC "main"
OP_CONST 0, t1
OP_STORE i, t1
OP_LABEL ".L1"
OP_LOAD i, t2
OP_CONST 10, t3
OP_JUMP_IF_GTE t2, t3, ".L2"
OP_LOAD i, t4
OP_CONST 1, t5
OP_ADD t4, t5, t6
OP_STORE i, t6
OP_JUMP ".L1"
OP_LABEL ".L2"
OP_LOAD i, t7
OP_CONST 7, t8
OP_MUL t7, t8, t9
OP_CONST 7, t10
OP_ADD t9, t10, t11
OP_RETURN t11
OP_FUNC_END

@endtest

@test("It should generate IR code on while loop statement with expression >")
@given("stdin")
int main() {
    int i;
    i = 20;
    while (i > 10) {
        i = i - 1;
    }
    return i * 7 + 7;
}
@whenRun("./bin/cclynx", args="--emit-ir /dev/stdin")
@expectOutput("stdout")
OP_FUNC "main"
OP_CONST 20, t1
OP_STORE i, t1
OP_LABEL ".L1"
OP_LOAD i, t2
OP_CONST 10, t3
OP_JUMP_IF_LTE t2, t3, ".L2"
OP_LOAD i, t4
OP_CONST 1, t5
OP_SUB t4, t5, t6
OP_STORE i, t6
OP_JUMP ".L1"
OP_LABEL ".L2"
OP_LOAD i, t7
OP_CONST 7, t8
OP_MUL t7, t8, t9
OP_CONST 7, t10
OP_ADD t9, t10, t11
OP_RETURN t11
OP_FUNC_END

@endtest

@test("It should generate IR code on while loop statement with expression ==")
@given("stdin")
int main() {
    int i;
    i = 0;
    while (i == 0) {
        i = i + 7;
    }
    return i;
}
@whenRun("./bin/cclynx", args="--emit-ir /dev/stdin")
@expectOutput("stdout")
OP_FUNC "main"
OP_CONST 0, t1
OP_STORE i, t1
OP_LABEL ".L1"
OP_LOAD i, t2
OP_CONST 0, t3
OP_JUMP_IF_NE t2, t3, ".L2"
OP_LOAD i, t4
OP_CONST 7, t5
OP_ADD t4, t5, t6
OP_STORE i, t6
OP_JUMP ".L1"
OP_LABEL ".L2"
OP_LOAD i, t7
OP_RETURN t7
OP_FUNC_END

@endtest

@test("It should generate IR code on while loop statement with expression !=")
@given("stdin")
int main() {
    int i;
    i = 10;
    while (i != 3) {
        i = i - 1;
    }
    return i;
}
@whenRun("./bin/cclynx", args="--emit-ir /dev/stdin")
@expectOutput("stdout")
OP_FUNC "main"
OP_CONST 10, t1
OP_STORE i, t1
OP_LABEL ".L1"
OP_LOAD i, t2
OP_CONST 3, t3
OP_JUMP_IF_EQ t2, t3, ".L2"
OP_LOAD i, t4
OP_CONST 1, t5
OP_SUB t4, t5, t6
OP_STORE i, t6
OP_JUMP ".L1"
OP_LABEL ".L2"
OP_LOAD i, t7
OP_RETURN t7
OP_FUNC_END

@endtest

@test("It should generate IR code on while loop statement with constant false condition")
@given("stdin")
int main() {
    int i;
    i = 1;
    while (0) {
        i = i + 1;
    }
    return i;
}
@whenRun("./bin/cclynx", args="--emit-ir /dev/stdin")
@expectOutput("stdout")
OP_FUNC "main"
OP_CONST 1, t1
OP_STORE i, t1
OP_LABEL ".L1"
OP_CONST 0, t2
OP_JUMP_IF_FALSE t2, ".L2"
OP_LOAD i, t3
OP_CONST 1, t4
OP_ADD t3, t4, t5
OP_STORE i, t5
OP_JUMP ".L1"
OP_LABEL ".L2"
OP_LOAD i, t6
OP_RETURN t6
OP_FUNC_END

@endtest

@test("It should generate IR code on while loop statement with constant true condition")
@given("stdin")
int main() {
    int i;
