@test("It should generate IR code for if statement with constant false expression")
@given("file")
int main() {
    int i;
    i = 4;
    if (0) {
        i = 50;
    }
    return i;
}
@whenRun("./bin/cclynx", args="--emit-ir")
@expectOutput("stdout")
OP_FUNC "main"
OP_CONST 4, t1
OP_STORE i, t1
OP_CONST 0, t2
OP_JUMP_IF_FALSE t2, ".L1"
OP_CONST 50, t3
OP_STORE i, t3
OP_LABEL ".L1"
OP_LOAD i, t4
OP_RETURN t4
OP_FUNC_END

@endtest

@test("It should generate IR code for if statement with constant true expression")
@given("file")
int main() {
    int i;
    i = 4;
    if (1) {
        i = 50;
    }
    return i;
}
@whenRun("./bin/cclynx", args="--emit-ir")
@expectOutput("stdout")
OP_FUNC "main"
OP_CONST 4, t1
OP_STORE i, t1
OP_CONST 1, t2
OP_JUMP_IF_FALSE t2, ".L1"
OP_CONST 50, t3
OP_STORE i, t3
OP_LABEL ".L1"
OP_LOAD i, t4
OP_RETURN t4
OP_FUNC_END

@endtest

@test("It should generate IR code for if statement with empty expression statement")
@given("file")
int main() {
    if (0);
    return 0;
}
@whenRun("./bin/cclynx", args="--emit-ir")
@expectOutput("stdout")
OP_FUNC "main"
OP_CONST 0, t1
OP_JUMP_IF_FALSE t1, ".L1"
OP_NOP
OP_LABEL ".L1"
OP_CONST 0, t2
OP_RETURN t2
OP_FUNC_END

@endtest

@test("It should generate IR code for if statement with empty compound statement")
@given("file")
int main() {
    if (0) {
    }
    return 0;
}
@whenRun("./bin/cclynx", args="--emit-ir")
@expectOutput("stdout")
OP_FUNC "main"
OP_CONST 0, t1
OP_JUMP_IF_FALSE t1, ".L1"
OP_NOP
OP_LABEL ".L1"
OP_CONST 0, t2
OP_RETURN t2
OP_FUNC_END

@endtest

@test("It should generate IR code for if statement with relational expression <")
@given("file")
int main() {
    int i;
    i = 0;
    if (i < 10) {
        i = i + 1;
    }
    return i;
}
@whenRun("./bin/cclynx", args="--emit-ir")
@expectOutput("stdout")
OP_FUNC "main"
OP_CONST 0, t1
OP_STORE i, t1
OP_LOAD i, t2
OP_CONST 10, t3
OP_JUMP_IF_GTE t2, t3, ".L1"
OP_LOAD i, t4
OP_CONST 1, t5
OP_ADD t4, t5, t6
OP_STORE i, t6
OP_LABEL ".L1"
OP_LOAD i, t7
OP_RETURN t7
OP_FUNC_END

@endtest

@test("It should generate IR code for if statement with relational expression >")
@given("file")
int main() {
    int i;
    i = 3;
    if (i > 1) {
        i = i - 1;
    }
    return i;
}
@whenRun("./bin/cclynx", args="--emit-ir")
@expectOutput("stdout")
OP_FUNC "main"
OP_CONST 3, t1
OP_STORE i, t1
OP_LOAD i, t2
OP_CONST 1, t3
OP_JUMP_IF_LTE t2, t3, ".L1"
OP_LOAD i, t4
OP_CONST 1, t5
OP_SUB t4, t5, t6
OP_STORE i, t6
OP_LABEL ".L1"
OP_LOAD i, t7
OP_RETURN t7
OP_FUNC_END

@endtest

@test("It should generate IR code for if statement with equality expression ==")
@given("file")
int main() {
    int i;
    i = 0;
    if (i == 0) {
        i = i + 7;
    }
    return i;
}
@whenRun("./bin/cclynx", args="--emit-ir")
@expectOutput("stdout")
OP_FUNC "main"
OP_CONST 0, t1
OP_STORE i, t1
OP_LOAD i, t2
OP_CONST 0, t3
OP_JUMP_IF_NE t2, t3, ".L1"
OP_LOAD i, t4
OP_CONST 7, t5
OP_ADD t4, t5, t6
OP_STORE i, t6
OP_LABEL ".L1"
OP_LOAD i, t7
OP_RETURN t7
OP_FUNC_END

@endtest

@test("It should generate IR code for if statement with equality expression !=")
@given("file")
int main() {
    int i;
    i = 10;
    if (i != 3) {
        i = i - 1;
    }
    return i;
}
@whenRun("./bin/cclynx", args="--emit-ir")
@expectOutput("stdout")
OP_FUNC "main"
OP_CONST 10, t1
OP_STORE i, t1
OP_LOAD i, t2
OP_CONST 3, t3
OP_JUMP_IF_EQ t2, t3, ".L1"
OP_LOAD i, t4
OP_CONST 1, t5
OP_SUB t4, t5, t6
OP_STORE i, t6
OP_LABEL ".L1"
OP_LOAD i, t7
OP_RETURN t7
OP_FUNC_END

@endtest

@test("It should generate IR code for if statement with else statement")
@given("file")
int main() {
    int i;
    i = 10;
    if (0) {
        i = i - 1;
    } else {
        i = i * 15;
    }
    return i;
}
@whenRun("./bin/cclynx", args="--emit-ir")
@expectOutput("stdout")
OP_FUNC "main"
OP_CONST 10, t1
OP_STORE i, t1
OP_CONST 0, t2
OP_JUMP_IF_FALSE t2, ".L1"
OP_LOAD i, t3
OP_CONST 1, t4
OP_SUB t3, t4, t5
OP_STORE i, t5
OP_JUMP ".L2"
OP_LABEL ".L1"
OP_LOAD i, t6
OP_CONST 15, t7
OP_MUL t6, t7, t8
OP_STORE i, t8
OP_LABEL ".L2"
OP_LOAD i, t9
OP_RETURN t9
OP_FUNC_END

@endtest

@test("It should generate IR code for if statement with empty compound statement for else")
@given("file")
int main() {
    int i;
    i = 10;
    if (0) {
        i = i - 1;
    } else {
    }
    return i;
}
@whenRun("./bin/cclynx", args="--emit-ir")
@expectOutput("stdout")
OP_FUNC "main"
OP_CONST 10, t1
OP_STORE i, t1
OP_CONST 0, t2
OP_JUMP_IF_FALSE t2, ".L1"
OP_LOAD i, t3
OP_CONST 1, t4
OP_SUB t3, t4, t5
OP_STORE i, t5
OP_JUMP ".L2"
OP_LABEL ".L1"
OP_NOP
OP_LABEL ".L2"
OP_LOAD i, t6
OP_RETURN t6
OP_FUNC_END

@endtest

@test("It should generate IR code for if statement with empty expression statement for else")
@given("file")
int main() {
    int i;
    i = 10;
    if (0) {
        i = i - 1;
    } else
        ;
    return i;
}
@whenRun("./bin/cclynx", args="--emit-ir")
@expectOutput("stdout")
OP_FUNC "main"
OP_CONST 10, t1
OP_STORE i, t1
OP_CONST 0, t2
OP_JUMP_IF_FALSE t2, ".L1"
OP_LOAD i, t3
OP_CONST 1, t4
OP_SUB t3, t4, t5
OP_STORE i, t5
OP_JUMP ".L2"
OP_LABEL ".L1"
OP_NOP
OP_LABEL ".L2"
OP_LOAD i, t6
OP_RETURN t6
OP_FUNC_END

@endtest

