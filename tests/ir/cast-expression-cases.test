@test("It should generate IR code an additive expression with float and cast type on return")
@given("file")
int main() {
    float x;
    x = 1.5;
    float y;
    y = 2.25;
    float z;
    z = x + y;
    z = z - 1.0;
    return (int)z;
}
@whenRun("./bin/cclynx", args="--emit-ir")
@expectOutput("stdout")
OP_FUNC "main"
OP_CONST 1.500000, t1
OP_STORE x, t1
OP_CONST 2.250000, t2
OP_STORE y, t2
OP_LOAD x, t3
OP_LOAD y, t4
OP_ADD t3, t4, t5
OP_STORE z, t5
OP_LOAD z, t6
OP_CONST 1.000000, t7
OP_SUB t6, t7, t8
OP_STORE z, t8
OP_LOAD z, t9
OP_INT_CAST t9, t10
OP_RETURN t10
OP_FUNC_END

@endtest

@test("It should generate IR code a multiplicative expression with float and cast type on return")
@given("file")
int main() {
    float x;
    x = 1.5;
    float y;
    y = 2.25;
    float z;
    z = x * y;
    z = z / 2.0;
    return (int)z;
}
@whenRun("./bin/cclynx", args="--emit-ir")
@expectOutput("stdout")
OP_FUNC "main"
OP_CONST 1.500000, t1
OP_STORE x, t1
OP_CONST 2.250000, t2
OP_STORE y, t2
OP_LOAD x, t3
OP_LOAD y, t4
OP_MUL t3, t4, t5
OP_STORE z, t5
OP_LOAD z, t6
OP_CONST 2.000000, t7
OP_DIV t6, t7, t8
OP_STORE z, t8
OP_LOAD z, t9
OP_INT_CAST t9, t10
OP_RETURN t10
OP_FUNC_END

@endtest

@test("It should generate IR code a relational expression with float and cast type on return")
@given("file")
int main() {
    float x;
    x = 1.5;
    float y;
    y = 2.25;
    int z;
    z = x < y;
    int w;
    w = y > 2.0;
    return (int)w;
}
@whenRun("./bin/cclynx", args="--emit-ir")
@expectOutput("stdout")
OP_FUNC "main"
OP_CONST 1.500000, t1
OP_STORE x, t1
OP_CONST 2.250000, t2
OP_STORE y, t2
OP_LOAD x, t3
OP_LOAD y, t4
OP_IS_LESS_THAN t3, t4, t5
OP_STORE z, t5
OP_LOAD y, t6
OP_CONST 2.000000, t7
OP_IS_GREATER_THAN t6, t7, t8
OP_STORE w, t8
OP_LOAD w, t9
OP_INT_CAST t9, t10
OP_RETURN t10
OP_FUNC_END

@endtest

@test("It should generate IR code for an integer cast to a float")
@given("file")
float test() {
    int y;
    y = 777;
    float x;
    x = (float)y;
    return x;
}
@whenRun("./bin/cclynx", args="--emit-ir")
@expectOutput("stdout")
OP_FUNC "test"
OP_CONST 777, t1
OP_STORE y, t1
OP_LOAD y, t2
OP_FLOAT_CAST t2, t3
OP_STORE x, t3
OP_LOAD x, t4
OP_RETURN t4
OP_FUNC_END

@endtest
