@test("It should generate target arm64 code an additive expression with float and cast type on return")
@given("file")
int main() {
    float x;
    x = 1.5;
    float y;
    y = 2.25;
    float z;
    z = x + y;
    z = z - 1.0;
    return (int)z;
}
@whenRun("./bin/cclynx", args="--emit-asm")
@expectOutput("stdout")
.text
.align 2

.global _main
_main:
    stp x29, x30, [sp, -16]!
    mov x29, sp
    sub sp, sp, #16
    movz w9, #0x0
    movk w9, #0x3fc0, lsl #16
    fmov s8, w9
    str s8, [sp, #0]
    movz w9, #0x0
    movk w9, #0x4010, lsl #16
    fmov s8, w9
    str s8, [sp, #4]
    ldr s8, [sp, #0]
    ldr s9, [sp, #4]
    fadd s10, s8, s9
    str s10, [sp, #8]
    ldr s8, [sp, #8]
    movz w9, #0x0
    movk w9, #0x3f80, lsl #16
    fmov s9, w9
    fsub s10, s8, s9
    str s10, [sp, #8]
    ldr s8, [sp, #8]
    fcvtzs w9, s8
    mov w0, w9
    add sp, sp, #16
    ldp x29, x30, [sp], #16
    ret

@endtest

@test("It should generate target arm64 code a multiplicative expression with float and cast type on return")
@given("file")
int main() {
    float x;
    x = 1.5;
    float y;
    y = 2.25;
    float z;
    z = x * y;
    z = z / 2.0;
    return (int)z;
}
@whenRun("./bin/cclynx", args="--emit-asm")
@expectOutput("stdout")
.text
.align 2

.global _main
_main:
    stp x29, x30, [sp, -16]!
    mov x29, sp
    sub sp, sp, #16
    movz w9, #0x0
    movk w9, #0x3fc0, lsl #16
    fmov s8, w9
    str s8, [sp, #0]
    movz w9, #0x0
    movk w9, #0x4010, lsl #16
    fmov s8, w9
    str s8, [sp, #4]
    ldr s8, [sp, #0]
    ldr s9, [sp, #4]
    fmul s10, s8, s9
    str s10, [sp, #8]
    ldr s8, [sp, #8]
    movz w9, #0x0
    movk w9, #0x4000, lsl #16
    fmov s9, w9
    fdiv s10, s8, s9
    str s10, [sp, #8]
    ldr s8, [sp, #8]
    fcvtzs w9, s8
    mov w0, w9
    add sp, sp, #16
    ldp x29, x30, [sp], #16
    ret

@endtest

@test("It should generate target arm64 code a relational expression with float and cast type on return")
@given("file")
int main() {
    float x;
    x = 1.5;
    float y;
    y = 2.25;
    int z;
    z = x < y;
    int w;
    w = y > 2.0;
    return w;
}
@whenRun("./bin/cclynx", args="--emit-asm")
@expectOutput("stdout")
.text
.align 2

.global _main
_main:
    stp x29, x30, [sp, -16]!
    mov x29, sp
    sub sp, sp, #16
    movz w9, #0x0
    movk w9, #0x3fc0, lsl #16
    fmov s8, w9
    str s8, [sp, #0]
    movz w9, #0x0
    movk w9, #0x4010, lsl #16
    fmov s8, w9
    str s8, [sp, #4]
    ldr s8, [sp, #0]
    ldr s9, [sp, #4]
    fcmp s8, s9
    cset w9, lt
    str w9, [sp, #8]
    ldr s8, [sp, #4]
    movz w9, #0x0
    movk w9, #0x4000, lsl #16
    fmov s9, w9
    fcmp s8, s9
    cset w9, gt
    str w9, [sp, #12]
    ldr w9, [sp, #12]
    mov w0, w9
    add sp, sp, #16
    ldp x29, x30, [sp], #16
    ret

@endtest

@test("It should generate target arm64 code for an integer cast to a float")
@given("file")
float test() {
    int y;
    y = 777;
    float x;
    x = (float)y;
    return x;
}
@whenRun("./bin/cclynx", args="--emit-asm")
@expectOutput("stdout")
.text
.align 2

.global _test
_test:
    stp x29, x30, [sp, -16]!
    mov x29, sp
    sub sp, sp, #16
    mov w9, #777
    str w9, [sp, #0]
    ldr w9, [sp, #0]
    scvtf s8, w9
    str s8, [sp, #4]
    ldr s8, [sp, #4]
    fmov s0, s8
    add sp, sp, #16
    ldp x29, x30, [sp], #16
    ret

@endtest
