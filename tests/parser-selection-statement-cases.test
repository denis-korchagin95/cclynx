@test("It should parse if statement with else (compound statement)")
@given("file", filename="sel_6.c")
int main() {
    int x;
    x = 10;
    if (x < 5)
        x = 10;
    else {
        x = 77;
        x = x - 1;
    }
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: 'sel_6.c'
|
+-> FunctionDefinition: 'main' {type: 'int'} <unspecified-parameters>
    |
    +-> CompoundStatement
        |
        +-> VariableDeclaration: 'x' {type: 'int'}
        |
        +-> ExpressionStatement
        |   |
        |   +-> AssignmentExpression: '='
        |       |
        |       +-> Variable: 'x' {type: 'int'}
        |       |
        |       +-> IntegerConstant: '10' {type: 'int'}
        |
        +-> IfStatement
            |
            +-> (condition) RelationalExpression: '<' {type: 'int'}
            |   |
            |   +-> Variable: 'x' {type: 'int'}
            |   |
            |   +-> IntegerConstant: '5' {type: 'int'}
            |
            +-> (true branch) ExpressionStatement
            |   |
            |   +-> AssignmentExpression: '='
            |       |
            |       +-> Variable: 'x' {type: 'int'}
            |       |
            |       +-> IntegerConstant: '10' {type: 'int'}
            |
            +-> (false branch) CompoundStatement
                |
                +-> ExpressionStatement
                |   |
                |   +-> AssignmentExpression: '='
                |       |
                |       +-> Variable: 'x' {type: 'int'}
                |       |
                |       +-> IntegerConstant: '77' {type: 'int'}
                |
                +-> ExpressionStatement
                    |
                    +-> AssignmentExpression: '='
                        |
                        +-> Variable: 'x' {type: 'int'}
                        |
                        +-> AdditiveExpression: '-' {type: 'int'}
                            |
                            +-> Variable: 'x' {type: 'int'}
                            |
                            +-> IntegerConstant: '1' {type: 'int'}

@endtest
