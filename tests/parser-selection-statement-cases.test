@test("It should parse if statement (single statement)")
@given("file", filename="sel_1.c")
int main() {
    int x;
    x = 10;
    if (x < 5)
        x = 10;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: 'sel_1.c'
|
+-> FunctionDefinition: 'main' {type: 'int'} <unspecified-parameters>
    |
    +-> CompoundStatement
        |
        +-> VariableDeclaration: 'x' {type: 'int'}
        |
        +-> ExpressionStatement
        |   |
        |   +-> AssignmentExpression: '='
        |       |
        |       +-> Variable: 'x' {type: 'int'}
        |       |
        |       +-> IntegerConstant: '10' {type: 'int'}
        |
        +-> IfStatement
            |
            +-> (condition) RelationalExpression: '<' {type: 'int'}
            |   |
            |   +-> Variable: 'x' {type: 'int'}
            |   |
            |   +-> IntegerConstant: '5' {type: 'int'}
            |
            +-> (true branch) ExpressionStatement
                |
                +-> AssignmentExpression: '='
                    |
                    +-> Variable: 'x' {type: 'int'}
                    |
                    +-> IntegerConstant: '10' {type: 'int'}

@endtest

@test("It should parse if statement (empty expression)")
@given("file", filename="sel_2.c")
int main() {
    int x;
    x = 10;
    if (x < 5);
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: 'sel_2.c'
|
+-> FunctionDefinition: 'main' {type: 'int'} <unspecified-parameters>
    |
    +-> CompoundStatement
        |
        +-> VariableDeclaration: 'x' {type: 'int'}
        |
        +-> ExpressionStatement
        |   |
        |   +-> AssignmentExpression: '='
        |       |
        |       +-> Variable: 'x' {type: 'int'}
        |       |
        |       +-> IntegerConstant: '10' {type: 'int'}
        |
        +-> IfStatement
            |
            +-> (condition) RelationalExpression: '<' {type: 'int'}
            |   |
            |   +-> Variable: 'x' {type: 'int'}
            |   |
            |   +-> IntegerConstant: '5' {type: 'int'}
            |
            +-> (true branch) ExpressionStatement: {empty expression}

@endtest

@test("It should parse if statement (compound statement)")
@given("file", filename="sel_3.c")
int main() {
    int x;
    x = 10;
    if (x < 5) {
        x = 10;
        x = x + 15;
    }
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: 'sel_3.c'
|
+-> FunctionDefinition: 'main' {type: 'int'} <unspecified-parameters>
    |
    +-> CompoundStatement
        |
        +-> VariableDeclaration: 'x' {type: 'int'}
        |
        +-> ExpressionStatement
        |   |
        |   +-> AssignmentExpression: '='
        |       |
        |       +-> Variable: 'x' {type: 'int'}
        |       |
        |       +-> IntegerConstant: '10' {type: 'int'}
        |
        +-> IfStatement
            |
            +-> (condition) RelationalExpression: '<' {type: 'int'}
            |   |
            |   +-> Variable: 'x' {type: 'int'}
            |   |
            |   +-> IntegerConstant: '5' {type: 'int'}
            |
            +-> (true branch) CompoundStatement
                |
                +-> ExpressionStatement
                |   |
                |   +-> AssignmentExpression: '='
                |       |
                |       +-> Variable: 'x' {type: 'int'}
                |       |
                |       +-> IntegerConstant: '10' {type: 'int'}
                |
                +-> ExpressionStatement
                    |
                    +-> AssignmentExpression: '='
                        |
                        +-> Variable: 'x' {type: 'int'}
                        |
                        +-> AdditiveExpression: '+' {type: 'int'}
                            |
                            +-> Variable: 'x' {type: 'int'}
                            |
                            +-> IntegerConstant: '15' {type: 'int'}

@endtest

@test("It should parse if statement with else (single statement)")
@given("file", filename="sel_4.c")
int main() {
    int x;
    x = 10;
    if (x < 5)
        x = 10;
    else
        x = 77;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: 'sel_4.c'
|
+-> FunctionDefinition: 'main' {type: 'int'} <unspecified-parameters>
    |
    +-> CompoundStatement
        |
        +-> VariableDeclaration: 'x' {type: 'int'}
        |
        +-> ExpressionStatement
        |   |
        |   +-> AssignmentExpression: '='
        |       |
        |       +-> Variable: 'x' {type: 'int'}
        |       |
        |       +-> IntegerConstant: '10' {type: 'int'}
        |
        +-> IfStatement
            |
            +-> (condition) RelationalExpression: '<' {type: 'int'}
            |   |
            |   +-> Variable: 'x' {type: 'int'}
            |   |
            |   +-> IntegerConstant: '5' {type: 'int'}
            |
            +-> (true branch) ExpressionStatement
            |   |
            |   +-> AssignmentExpression: '='
            |       |
            |       +-> Variable: 'x' {type: 'int'}
            |       |
            |       +-> IntegerConstant: '10' {type: 'int'}
            |
            +-> (false branch) ExpressionStatement
                |
                +-> AssignmentExpression: '='
                    |
                    +-> Variable: 'x' {type: 'int'}
                    |
                    +-> IntegerConstant: '77' {type: 'int'}

@endtest

@test("It should parse if statement with else (empty expression)")
