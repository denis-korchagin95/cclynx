@test("It should parse source from a file")
@given("file")
int main() {
    return 42;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
|
+-> FunctionDefinition: 'main' {type: 'int'} <unspecified-parameters>
    |
    +-> CompoundStatement
        |
        +-> ReturnStatement
            |
            +-> IntegerConstant: '42' {type: 'int'}

@endtest

@test("It should parse source from stdin via /dev/stdin")
@given("file")
int main() {
    return 42;
}
@whenRun("./scripts/cclynx-stdin-runner.sh", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: 'stdin'
|
+-> FunctionDefinition: 'main' {type: 'int'} <unspecified-parameters>
    |
    +-> CompoundStatement
        |
        +-> ReturnStatement
            |
            +-> IntegerConstant: '42' {type: 'int'}

@endtest

@test("It should report errors when parsing from stdin via /dev/stdin")
@given("file")
int main() {
    float int x;
    return 0;
}
@whenRun("./scripts/cclynx-stdin-runner.sh", args="--emit-ast")
@expectOutput("stderr")
{{any}}:2:11: ERROR: mixed types
{{any}}:2:16: WARNING: unused variable 'x'

@endtest
