{{any}}:10:5: ERROR: undeclared variable 'a8'
{{any}}:11:5: ERROR: undeclared variable 'a9'
{{any}}:12:5: ERROR: undeclared variable 'b0'
{{any}}:13:5: ERROR: undeclared variable 'b1'
{{any}}:14:5: ERROR: undeclared variable 'b2'
{{any}}:15:5: ERROR: undeclared variable 'b3'
{{any}}:16:5: ERROR: undeclared variable 'b4'
{{any}}:17:5: ERROR: undeclared variable 'b5'
