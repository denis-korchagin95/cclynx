@test("It should report multiple undeclared variable errors")
@given("file")
int main() {
    int result;
    result = x + 1;
    result = y + 2;
}
@whenRun("./bin/cclynx", args="--emit-ast --no-warnings")
@expectOutput("stderr")
{{any}}:3:14: ERROR: undeclared variable 'x'
{{any}}:4:14: ERROR: undeclared variable 'y'

@endtest

@test("It should report redeclared variable and undeclared variable errors together")
@given("file")
int main() {
    int x;
    int x;
    y = 1;
}
@whenRun("./bin/cclynx", args="--emit-ast --no-warnings")
@expectOutput("stderr")
{{any}}:3:9: ERROR: variable 'x' already declared
{{any}}:4:5: ERROR: undeclared variable 'y'

@endtest

@test("It should report function redefinition and error inside duplicate body")
@given("file")
int foo() {
    return 1;
}

int foo() {
    return x;
}
@whenRun("./bin/cclynx", args="--emit-ast --no-warnings")
@expectOutput("stderr")
{{any}}:5:5: ERROR: function 'foo' already defined
{{any}}:6:12: ERROR: undeclared variable 'x'

@endtest

@test("It should report errors in both if branches")
@given("file")
int main() {
    int x;
    if (x) {
        y = 1;
    } else {
        z = 2;
    }
    return 0;
}
@whenRun("./bin/cclynx", args="--emit-ast --no-warnings")
@expectOutput("stderr")
{{any}}:4:9: ERROR: undeclared variable 'y'
{{any}}:6:9: ERROR: undeclared variable 'z'

@endtest

@test("It should report multiple argument type mismatches")
@given("file")
int add(int a, int b) {
    return a + b;
}

int main() {
    return add((float) 1, (float) 2);
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stderr")
{{any}}:6:12: ERROR: argument 1 of function 'add' has type 'float' but expected 'int'
{{any}}:6:12: ERROR: argument 2 of function 'add' has type 'float' but expected 'int'

@endtest

@test("It should report errors across multiple functions")
@given("file")
int foo() {
    return x;
}

int bar() {
    return y;
}
@whenRun("./bin/cclynx", args="--emit-ast --no-warnings")
@expectOutput("stderr")
{{any}}:2:12: ERROR: undeclared variable 'x'
{{any}}:6:12: ERROR: undeclared variable 'y'

@endtest

@test("It should recover from syntax error and report subsequent semantic error")
@given("file")
int main() {
    int x;
    x = 1
    int y;
    y = z;
    return 0;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stderr")
{{any}}:4:5: ERROR: expected ';' but got keyword 'int'
{{any}}:5:5: ERROR: undeclared variable 'y'

@endtest

@test("It should report unknown function call error and continue")
@given("file")
int main() {
    int x;
    x = unknown(1, 2);
    x = y;
    return x;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stderr")
{{any}}:3:9: ERROR: call to undeclared function 'unknown'
{{any}}:4:9: ERROR: undeclared variable 'y'

@endtest

@test("It should limit the number of reported errors")
@given("file")
int main() {
    a0 = 0;
    a1 = 0;
    a2 = 0;
    a3 = 0;
    a4 = 0;
    a5 = 0;
    a6 = 0;
    a7 = 0;
    a8 = 0;
    a9 = 0;
    b0 = 0;
    b1 = 0;
