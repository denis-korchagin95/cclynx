    b3 = 0;
    b4 = 0;
    b5 = 0;
    b6 = 0;
    b7 = 0;
    b8 = 0;
    b9 = 0;
    c0 = 0;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stderr")
{{any}}:2:5: ERROR: undeclared variable 'a0'
{{any}}:3:5: ERROR: undeclared variable 'a1'
