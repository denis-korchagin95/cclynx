@test("It should suppress sign-compare with -Wall -Wno-sign-compare")
@given("stdin")
unsigned int foo(unsigned int x, int y) {
    return x < y;
}
@whenRun("./bin/cclynx", args="--emit-ast -Wall -Wno-sign-compare /dev/stdin")
@expectOutput("stderr")

@endtest

