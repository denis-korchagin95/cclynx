@test("It should parse if statement (single statement)")
@given("file")
int main() {
    int x;
    x = 10;
    if (x < 5)
        x = 10;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
|
+-> FunctionDefinition: 'main' <unspecified-parameters>
    |
    +-> ReturnType
    |   |
    |   +-> category: 'basic'
    |   |
    |   +-> descriptor: 'int'
    |
    +-> CompoundStatement
        |
        +-> VariableDeclaration: 'x'
        |   |
        |   +-> Type
        |       |
        |       +-> category: 'basic'
        |       |
        |       +-> descriptor: 'int'
        |
        +-> ExpressionStatement
        |   |
        |   +-> AssignmentExpression: '='
        |       |
        |       +-> VariableExpression: 'x'
        |       |   |
        |       |   +-> Type
        |       |       |
        |       |       +-> category: 'basic'
        |       |       |
        |       |       +-> descriptor: 'int'
        |       |
        |       +-> IntegerConstant: '10'
        |           |
        |           +-> Type
        |               |
        |               +-> category: 'basic'
        |               |
        |               +-> descriptor: 'int'
        |
        +-> IfStatement
            |
            +-> (condition) RelationalExpression: '<'
            |   |
            |   +-> Type
            |   |   |
            |   |   +-> category: 'basic'
            |   |   |
            |   |   +-> descriptor: 'int'
            |   |
            |   +-> VariableExpression: 'x'
            |   |   |
            |   |   +-> Type
            |   |       |
            |   |       +-> category: 'basic'
            |   |       |
            |   |       +-> descriptor: 'int'
            |   |
            |   +-> IntegerConstant: '5'
            |       |
            |       +-> Type
            |           |
            |           +-> category: 'basic'
            |           |
            |           +-> descriptor: 'int'
            |
            +-> (true branch) ExpressionStatement
                |
                +-> AssignmentExpression: '='
                    |
                    +-> VariableExpression: 'x'
                    |   |
                    |   +-> Type
                    |       |
                    |       +-> category: 'basic'
                    |       |
                    |       +-> descriptor: 'int'
                    |
                    +-> IntegerConstant: '10'
                        |
                        +-> Type
                            |
                            +-> category: 'basic'
                            |
                            +-> descriptor: 'int'

@endtest

