@test("It should allow additive expression with same unsigned type")
@given("file")
unsigned int foo() {
    unsigned int x;
    unsigned int y;
    x = 1;
    y = 2;
    return x + y;
}
@whenRun("./bin/cclynx", args="--emit-ast --no-warnings")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
└── FunctionDefinition: 'foo' <unspecified-parameters>
