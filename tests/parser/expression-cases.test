@test("It should insert implicit cast on equality expression with mixed signedness")
@given("file")
int main() {
    int x;
    unsigned int y;
    x = 1;
    y = 2;
    int z;
    z = x == y;
    return z;
}
@whenRun("./bin/cclynx", args="--emit-ast --no-warnings")
