@test("It should parse an integer constant")
@given("file", filename="expr_1.c")
int main() {
    777;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
└── FunctionDefinition: 'main' <unspecified-parameters>
    ├── ReturnType
    │   ├── category: 'basic'
    │   └── descriptor: 'int'
    └── CompoundStatement
        └── ExpressionStatement
            └── IntegerConstant: '777'
                └── Type
                    ├── category: 'basic'
                    └── descriptor: 'int'

@endtest

