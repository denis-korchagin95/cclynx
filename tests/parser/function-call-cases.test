@endtest


@test("It should parse function call with unspecified parameters and arguments provided")
@given("file")
int foo() {
   return 7;
}

int main() {
    return foo(42);
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
├── FunctionDefinition: 'foo' <unspecified-parameters>
│   ├── ReturnType
│   │   ├── category: 'basic'
│   │   └── descriptor: 'int'
│   └── CompoundStatement
│       └── ReturnStatement
│           └── IntegerConstant: '7'
│               └── Type
│                   ├── category: 'basic'
│                   └── descriptor: 'int'
└── FunctionDefinition: 'main' <unspecified-parameters>
    ├── ReturnType
    │   ├── category: 'basic'
    │   └── descriptor: 'int'
    └── CompoundStatement
        └── ReturnStatement
            └── FunctionCallExpression: 'foo' <1-argument>
                ├── ReturnType
                │   ├── category: 'basic'
                │   └── descriptor: 'int'
                └── IntegerConstant: '42'
                    └── Type
                        ├── category: 'basic'
                        └── descriptor: 'int'

@endtest

@test("It should parse function call with 1 argument")
@given("file")
int identity(int a) {
    return a;
}

int main() {
    return identity(42);
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
├── FunctionDefinition: 'identity' <1-parameter>
│   ├── ReturnType
