                │   └── descriptor: 'int'
                └── IntegerConstant: '42'
                    └── Type
                        ├── category: 'basic'
                        └── descriptor: 'int'

@endtest

@test("It should parse function call with 2 arguments")
@given("file")
int add(int a, int b) {
    return a + b;
}

int main() {
    return add(19, 23);
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
├── FunctionDefinition: 'add' <2-parameters>
│   ├── ReturnType
