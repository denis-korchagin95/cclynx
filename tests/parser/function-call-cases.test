@test("It should parse function calls without parameters")
@given("file")
int foo(void) {
   return 7;
}

int main() {
    return 42 * foo();
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
├── FunctionDefinition: 'foo' <no-parameters>
│   ├── ReturnType
│   │   ├── category: 'basic'
│   │   └── descriptor: 'int'
│   └── CompoundStatement
│       └── ReturnStatement
│           └── IntegerConstant: '7'
│               └── Type
│                   ├── category: 'basic'
│                   └── descriptor: 'int'
└── FunctionDefinition: 'main' <unspecified-parameters>
    ├── ReturnType
    │   ├── category: 'basic'
    │   └── descriptor: 'int'
    └── CompoundStatement
        └── ReturnStatement
            └── MultiplicativeExpression: '*'
                ├── Type
                │   ├── category: 'basic'
                │   └── descriptor: 'int'
                ├── IntegerConstant: '42'
                │   └── Type
                │       ├── category: 'basic'
                │       └── descriptor: 'int'
                └── FunctionCallExpression: 'foo' <no-arguments>
                    └── ReturnType
                        ├── category: 'basic'
                        └── descriptor: 'int'

@endtest

@test("It should parse function calls with unspecified parameters")
@given("file")
int foo() {
   return 7;
}

int main() {
    return 42 * foo();
}
@whenRun("./bin/cclynx", args="--emit-ast")
