@test("It should parse function calls without parameters")
@given("file")
int foo(void) {
   return 7;
}

int main() {
    return 42 * foo();
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
в”њв”Ђв”Ђ FunctionDefinition: 'foo' <no-parameters>
в”‚   в”њв”Ђв”Ђ ReturnType
в”‚   в”‚   в”њв”Ђв”Ђ category: 'basic'
в”‚   в”‚   в””в”Ђв”Ђ descriptor: 'int'
в”‚   в””в”Ђв”Ђ CompoundStatement
в”‚       в””в”Ђв”Ђ ReturnStatement
в”‚           в””в”Ђв”Ђ IntegerConstant: '7'
в”‚               в””в”Ђв”Ђ Type
в”‚                   в”њв”Ђв”Ђ category: 'basic'
в”‚                   в””в”Ђв”Ђ descriptor: 'int'
в””в”Ђв”Ђ FunctionDefinition: 'main' <unspecified-parameters>
    в”њв”Ђв”Ђ ReturnType
    в”‚   в”њв”Ђв”Ђ category: 'basic'
    в”‚   в””в”Ђв”Ђ descriptor: 'int'
    в””в”Ђв”Ђ CompoundStatement
        в””в”Ђв”Ђ ReturnStatement
            в””в”Ђв”Ђ MultiplicativeExpression: '*'
                в”њв”Ђв”Ђ Type
                в”‚   в”њв”Ђв”Ђ category: 'basic'
                в”‚   в””в”Ђв”Ђ descriptor: 'int'
                в”њв”Ђв”Ђ IntegerConstant: '42'
                в”‚   в””в”Ђв”Ђ Type
                в”‚       в”њв”Ђв”Ђ category: 'basic'
                в”‚       в””в”Ђв”Ђ descriptor: 'int'
                в””в”Ђв”Ђ FunctionCallExpression: 'foo' <no-arguments>
                    в””в”Ђв”Ђ Type
                        в”њв”Ђв”Ђ category: 'basic'
                        в””в”Ђв”Ђ descriptor: 'int'

@endtest

