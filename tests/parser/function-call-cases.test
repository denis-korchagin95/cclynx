│   │           ├── category: 'basic'
│   │           └── descriptor: 'int'
│   └── CompoundStatement
│       └── ReturnStatement
│           └── AdditiveExpression: '+'
│               ├── Type
│               │   ├── category: 'basic'
│               │   └── descriptor: 'int'
│               ├── VariableExpression: 'a'
│               │   └── Type
│               │       ├── category: 'basic'
│               │       └── descriptor: 'int'
│               └── VariableExpression: 'b'
│                   └── Type
│                       ├── category: 'basic'
│                       └── descriptor: 'int'
└── FunctionDefinition: 'main' <unspecified-parameters>
    ├── ReturnType
    │   ├── category: 'basic'
    │   └── descriptor: 'int'
    └── CompoundStatement
        └── ReturnStatement
            └── FunctionCallExpression: 'add' <2-arguments>
                ├── ReturnType
                │   ├── category: 'basic'
                │   └── descriptor: 'int'
                ├── IntegerConstant: '19'
