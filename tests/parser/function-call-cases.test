@test("It should raise an error on argument count mismatch")
@given("file")
int add(int a, int b) {
    return a + b;
}

int main() {
    return add(1);
}
@whenRun("./bin/cclynx", args="--emit-ast --no-warnings")
@expectOutput("stderr")
{{any}}:6:12: ERROR: function 'add' expects 2 arguments but 1 were provided

@endtest

@test("It should raise an error on argument type mismatch")
@given("file")
int identity(int a) {
    return a;
}

int main() {
    return identity((float) 1);
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stderr")
{{any}}:6:12: ERROR: argument 1 of function 'identity' has type 'float' but expected 'int'

@endtest

@test("It should raise an error when function call uses a keyword as name")
@given("file")
int main() {
    return 42 * while();
}
@whenRun("./bin/cclynx", args="--emit-ast --no-warnings")
@expectOutput("stderr")
{{any}}:2:17: ERROR: expected identifier but got keyword 'while'

@endtest
