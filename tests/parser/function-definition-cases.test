    │           ├── category: 'basic'
    │           └── descriptor: 'int'
    └── CompoundStatement
        └── ReturnStatement
            └── VariableExpression: 'a'
                └── Type
                    ├── category: 'basic'
                    └── descriptor: 'int'

@endtest

@test("It should parse function with 2 parameters")
@given("stdin")
int add(int a, int b) {
    return a + b;
}
@whenRun("./bin/cclynx", args="--emit-ast /dev/stdin")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
└── FunctionDefinition: 'add' <2-parameters>
    ├── ReturnType
    │   ├── category: 'basic'
    │   └── descriptor: 'int'
    ├── ParameterList
    │   ├── Parameter: 'a'
    │   │   └── Type
    │   │       ├── category: 'basic'
    │   │       └── descriptor: 'int'
    │   └── Parameter: 'b'
    │       └── Type
    │           ├── category: 'basic'
    │           └── descriptor: 'int'
    └── CompoundStatement
        └── ReturnStatement
            └── AdditiveExpression: '+'
                ├── Type
                │   ├── category: 'basic'
                │   └── descriptor: 'int'
                ├── VariableExpression: 'a'
                │   └── Type
                │       ├── category: 'basic'
                │       └── descriptor: 'int'
                └── VariableExpression: 'b'
                    └── Type
                        ├── category: 'basic'
                        └── descriptor: 'int'

@endtest

@test("It should parse function with 3 parameters")
@given("stdin")
int foo(int a, int b, int c) {
    return a + b * c;
}
@whenRun("./bin/cclynx", args="--emit-ast /dev/stdin")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
└── FunctionDefinition: 'foo' <3-parameters>
    ├── ReturnType
    │   ├── category: 'basic'
    │   └── descriptor: 'int'
    ├── ParameterList
    │   ├── Parameter: 'a'
    │   │   └── Type
    │   │       ├── category: 'basic'
    │   │       └── descriptor: 'int'
    │   ├── Parameter: 'b'
    │   │   └── Type
    │   │       ├── category: 'basic'
    │   │       └── descriptor: 'int'
    │   └── Parameter: 'c'
    │       └── Type
    │           ├── category: 'basic'
    │           └── descriptor: 'int'
    └── CompoundStatement
        └── ReturnStatement
            └── AdditiveExpression: '+'
                ├── Type
                │   ├── category: 'basic'
                │   └── descriptor: 'int'
                ├── VariableExpression: 'a'
                │   └── Type
                │       ├── category: 'basic'
                │       └── descriptor: 'int'
                └── MultiplicativeExpression: '*'
                    ├── Type
                    │   ├── category: 'basic'
                    │   └── descriptor: 'int'
                    ├── VariableExpression: 'b'
                    │   └── Type
                    │       ├── category: 'basic'
                    │       └── descriptor: 'int'
                    └── VariableExpression: 'c'
                        └── Type
                            ├── category: 'basic'
                            └── descriptor: 'int'

@endtest

@test("It should parse function with unsigned int return type")
@given("stdin")
unsigned int foo() {
    return 42;
}
@whenRun("./bin/cclynx", args="--emit-ast /dev/stdin")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
└── FunctionDefinition: 'foo' <unspecified-parameters>
    ├── ReturnType
    │   ├── category: 'basic'
    │   └── descriptor: 'unsigned int'
    └── CompoundStatement
        └── ReturnStatement
            └── CastExpression
                ├── Type
                │   ├── category: 'basic'
                │   └── descriptor: 'unsigned int'
                └── IntegerConstant: '42'
                    └── Type
                        ├── category: 'basic'
                        └── descriptor: 'int'

@endtest

