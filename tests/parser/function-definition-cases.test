                └── VariableExpression: 'a'
                    └── Type
                        ├── category: 'basic'
                        └── descriptor: 'unsigned int'

@endtest

@test("It should raise an error on function redefinition")
@given("stdin")
int foo() {
    return 1;
}

int foo() {
    return 2;
}
@whenRun("./bin/cclynx", args="--emit-ast /dev/stdin")
@expectOutput("stderr")
{{any}}:5:5: ERROR: function 'foo' already defined

@endtest

@test("It should raise an error when function name is a keyword")
@given("stdin")
int while() {
    return 1;
}
@whenRun("./bin/cclynx", args="--emit-ast /dev/stdin")
@expectOutput("stderr")
{{any}}:1:5: ERROR: expected identifier but got keyword 'while'

@endtest

@test("It should raise an error when parameter type is not a type specifier")
@given("stdin")
int foo(bar a) {
    return a;
}
@whenRun("./bin/cclynx", args="--emit-ast /dev/stdin")
@expectOutput("stderr")
{{any}}:1:9: ERROR: expected type specifier but got identifier 'bar'
{{any}}:1:9: ERROR: expected ')' but got identifier 'bar'

@endtest

@test("It should raise an error when parameter name is missing after type")
@given("stdin")
int foo(int) {
    return 0;
}
@whenRun("./bin/cclynx", args="--emit-ast /dev/stdin")
@expectOutput("stderr")
{{any}}:1:12: ERROR: expected identifier but got ')'

@endtest

@test("It should raise an error when parameter name is a keyword")
@given("stdin")
int foo(int return) {
    return 0;
}
@whenRun("./bin/cclynx", args="--emit-ast /dev/stdin")
@expectOutput("stderr")
{{any}}:1:13: ERROR: expected identifier but got keyword 'return'

@endtest

@test("It should raise an error when too many parameters")
@given("stdin")
int foo(int a, int b, int c, int d) {
    return 0;
}
@whenRun("./bin/cclynx", args="--emit-ast --no-warnings /dev/stdin")
@expectOutput("stderr")
{{any}}:1:28: ERROR: too many parameters, maximum is 3

@endtest

@test("It should insert implicit cast on return when signedness differs")
@given("stdin")
unsigned int foo() {
    int x;
    x = 1;
    return x;
}
@whenRun("./bin/cclynx", args="--emit-ast --no-warnings /dev/stdin")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
└── FunctionDefinition: 'foo' <unspecified-parameters>
    ├── ReturnType
    │   ├── category: 'basic'
    │   └── descriptor: 'unsigned int'
    └── CompoundStatement
        ├── VariableDeclaration: 'x'
        │   └── Type
        │       ├── category: 'basic'
        │       └── descriptor: 'int'
        ├── ExpressionStatement
        │   └── AssignmentExpression: '='
        │       ├── VariableExpression: 'x'
        │       │   └── Type
        │       │       ├── category: 'basic'
        │       │       └── descriptor: 'int'
        │       └── IntegerConstant: '1'
        │           └── Type
        │               ├── category: 'basic'
        │               └── descriptor: 'int'
        └── ReturnStatement
            └── CastExpression
                ├── Type
                │   ├── category: 'basic'
                │   └── descriptor: 'unsigned int'
                └── VariableExpression: 'x'
                    └── Type
                        ├── category: 'basic'
                        └── descriptor: 'int'

@endtest
