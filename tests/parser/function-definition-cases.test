@test("It should parse main function with void argument list")
@given("stdin")
int main(void) {
    return 42;
}
@whenRun("./bin/cclynx", args="--emit-ast /dev/stdin")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
└── FunctionDefinition: 'main' <no-parameters>
    ├── ReturnType
    │   ├── category: 'basic'
    │   └── descriptor: 'int'
    └── CompoundStatement
        └── ReturnStatement
            └── IntegerConstant: '42'
                └── Type
                    ├── category: 'basic'
                    └── descriptor: 'int'

@endtest

@test("It should parse main function (with basic expression)")
@given("stdin")
int main() {
    7 * 8;
}
@whenRun("./bin/cclynx", args="--emit-ast /dev/stdin")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
└── FunctionDefinition: 'main' <unspecified-parameters>
    ├── ReturnType
    │   ├── category: 'basic'
    │   └── descriptor: 'int'
    └── CompoundStatement
        └── ExpressionStatement
            └── MultiplicativeExpression: '*'
                ├── Type
                │   ├── category: 'basic'
                │   └── descriptor: 'int'
                ├── IntegerConstant: '7'
                │   └── Type
                │       ├── category: 'basic'
                │       └── descriptor: 'int'
                └── IntegerConstant: '8'
                    └── Type
                        ├── category: 'basic'
                        └── descriptor: 'int'

@endtest

@test("It should parse main function (with two variable declarations x and y)")
@given("stdin")
int main() {
    int x;
    int y;
}
@whenRun("./bin/cclynx", args="--emit-ast /dev/stdin")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
└── FunctionDefinition: 'main' <unspecified-parameters>
    ├── ReturnType
    │   ├── category: 'basic'
    │   └── descriptor: 'int'
    └── CompoundStatement
        ├── VariableDeclaration: 'x'
        │   └── Type
        │       ├── category: 'basic'
        │       └── descriptor: 'int'
        └── VariableDeclaration: 'y'
            └── Type
                ├── category: 'basic'
                └── descriptor: 'int'

@endtest

