@test("It should parse main function with return variable")
@given("stdin")
int main() {
    int result;
    result = 1;
    return result;
}
@whenRun("./bin/cclynx", args="--emit-ast /dev/stdin")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
└── FunctionDefinition: 'main' <unspecified-parameters>
    ├── ReturnType
    │   ├── category: 'basic'
    │   └── descriptor: 'int'
    └── CompoundStatement
        ├── VariableDeclaration: 'result'
        │   └── Type
        │       ├── category: 'basic'
        │       └── descriptor: 'int'
        ├── ExpressionStatement
        │   └── AssignmentExpression: '='
        │       ├── VariableExpression: 'result'
        │       │   └── Type
        │       │       ├── category: 'basic'
        │       │       └── descriptor: 'int'
        │       └── IntegerConstant: '1'
        │           └── Type
        │               ├── category: 'basic'
        │               └── descriptor: 'int'
        └── ReturnStatement
            └── VariableExpression: 'result'
                └── Type
                    ├── category: 'basic'
                    └── descriptor: 'int'

@endtest

@test("It should parse multiple function definitions")
@given("stdin")
int foo() {
    return 1;
}

int bar() {
    return 2;
}
@whenRun("./bin/cclynx", args="--emit-ast /dev/stdin")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
├── FunctionDefinition: 'foo' <unspecified-parameters>
│   ├── ReturnType
│   │   ├── category: 'basic'
│   │   └── descriptor: 'int'
│   └── CompoundStatement
│       └── ReturnStatement
│           └── IntegerConstant: '1'
│               └── Type
│                   ├── category: 'basic'
│                   └── descriptor: 'int'
└── FunctionDefinition: 'bar' <unspecified-parameters>
    ├── ReturnType
    │   ├── category: 'basic'
    │   └── descriptor: 'int'
    └── CompoundStatement
        └── ReturnStatement
            └── IntegerConstant: '2'
                └── Type
                    ├── category: 'basic'
                    └── descriptor: 'int'

@endtest

@test("It should parse multiple functions with same variable names in different scopes")
@given("stdin")
int foo() {
    int x;
    return x;
}

int bar() {
    int x;
    return x;
}
@whenRun("./bin/cclynx", args="--emit-ast /dev/stdin")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
├── FunctionDefinition: 'foo' <unspecified-parameters>
│   ├── ReturnType
│   │   ├── category: 'basic'
│   │   └── descriptor: 'int'
│   └── CompoundStatement
│       ├── VariableDeclaration: 'x'
│       │   └── Type
│       │       ├── category: 'basic'
│       │       └── descriptor: 'int'
│       └── ReturnStatement
│           └── VariableExpression: 'x'
│               └── Type
│                   ├── category: 'basic'
│                   └── descriptor: 'int'
└── FunctionDefinition: 'bar' <unspecified-parameters>
    ├── ReturnType
    │   ├── category: 'basic'
    │   └── descriptor: 'int'
    └── CompoundStatement
        ├── VariableDeclaration: 'x'
        │   └── Type
        │       ├── category: 'basic'
        │       └── descriptor: 'int'
        └── ReturnStatement
            └── VariableExpression: 'x'
                └── Type
                    ├── category: 'basic'
                    └── descriptor: 'int'

@endtest

@test("It should parse function with 1 parameter")
