            └── VariableExpression: 'x'
                └── Type
                    ├── category: 'basic'
                    └── descriptor: 'int'

@endtest

@test("It should raise an error on mixed types in variable declaration")
@given("file")
int main() {
    float int x;
    return 0;
}
@whenRun("./bin/cclynx", args="--emit-ast --no-warnings")
@expectOutput("stderr")
{{any}}:2:11: ERROR: mixed types

@endtest

@test("It should parse an implicitly signed integer variable")
@given("file")
int main() {
    int x;
    return 0;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
└── FunctionDefinition: 'main' <unspecified-parameters>
    ├── ReturnType
    │   ├── category: 'basic'
    │   └── descriptor: 'int'
    └── CompoundStatement
        ├── VariableDeclaration: 'x'
        │   └── Type
        │       ├── category: 'basic'
        │       └── descriptor: 'int'
        └── ReturnStatement
            └── IntegerConstant: '0'
                └── Type
                    ├── category: 'basic'
                    └── descriptor: 'int'

@endtest

@test("It should parse an explicitly unsigned integer variable")
@given("file")
int main() {
    unsigned int x;
    return 0;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
└── FunctionDefinition: 'main' <unspecified-parameters>
    ├── ReturnType
    │   ├── category: 'basic'
    │   └── descriptor: 'int'
    └── CompoundStatement
        ├── VariableDeclaration: 'x'
        │   └── Type
        │       ├── category: 'basic'
        │       └── descriptor: 'unsigned int'
        └── ReturnStatement
            └── IntegerConstant: '0'
                └── Type
                    ├── category: 'basic'
                    └── descriptor: 'int'

@endtest

@test("It should parse unsigned as an integer variable by default")
@given("file")
int main() {
    unsigned x;
    return 0;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
└── FunctionDefinition: 'main' <unspecified-parameters>
    ├── ReturnType
    │   ├── category: 'basic'
    │   └── descriptor: 'int'
    └── CompoundStatement
        ├── VariableDeclaration: 'x'
        │   └── Type
        │       ├── category: 'basic'
        │       └── descriptor: 'unsigned int'
        └── ReturnStatement
            └── IntegerConstant: '0'
                └── Type
                    ├── category: 'basic'
                    └── descriptor: 'int'

@endtest

@test("It should show an error if unsigned duplicates more than one time")
@given("file")
int main() {
    unsigned unsigned int x;
    return 0;
}
@whenRun("./bin/cclynx", args="--emit-ast --no-warnings")
@expectOutput("stderr")
{{any}}:2:14: ERROR: duplicate 'unsigned' keyword

@endtest

@test("It should raise an error when unsigned is applied to void")
@given("file")
unsigned void foo() {
    return;
}
@whenRun("./bin/cclynx", args="--emit-ast --no-warnings")
@expectOutput("stderr")
{{any}}:1:10: ERROR: 'unsigned' cannot be applied to 'void'

@endtest

@test("It should raise an error when unsigned is applied to float")
@given("file")
int main() {
    unsigned float x;
    return 0;
}
@whenRun("./bin/cclynx", args="--emit-ast --no-warnings")
@expectOutput("stderr")
{{any}}:2:14: ERROR: 'unsigned' cannot be applied to 'float'

@endtest
