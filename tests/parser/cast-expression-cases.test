@test("An integer can be cast to unsigned int")
@given("file")
int main() {
    int y;
    y = 42;
    unsigned int x;
    x = (unsigned int)y;
    return x;
}
@whenRun("./bin/cclynx", args="--emit-ast --no-warnings")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
└── FunctionDefinition: 'main' <unspecified-parameters>
    ├── ReturnType
    │   ├── category: 'basic'
    │   └── descriptor: 'int'
    └── CompoundStatement
        ├── VariableDeclaration: 'y'
        │   └── Type
        │       ├── category: 'basic'
        │       └── descriptor: 'int'
        ├── ExpressionStatement
        │   └── AssignmentExpression: '='
        │       ├── VariableExpression: 'y'
        │       │   └── Type
        │       │       ├── category: 'basic'
        │       │       └── descriptor: 'int'
        │       └── IntegerConstant: '42'
        │           └── Type
        │               ├── category: 'basic'
        │               └── descriptor: 'int'
        ├── VariableDeclaration: 'x'
        │   └── Type
        │       ├── category: 'basic'
        │       └── descriptor: 'unsigned int'
        ├── ExpressionStatement
        │   └── AssignmentExpression: '='
        │       ├── VariableExpression: 'x'
        │       │   └── Type
        │       │       ├── category: 'basic'
        │       │       └── descriptor: 'unsigned int'
        │       └── CastExpression
        │           ├── Type
        │           │   ├── category: 'basic'
        │           │   └── descriptor: 'unsigned int'
        │           └── VariableExpression: 'y'
        │               └── Type
        │                   ├── category: 'basic'
        │                   └── descriptor: 'int'
        └── ReturnStatement
            └── CastExpression
                ├── Type
                │   ├── category: 'basic'
                │   └── descriptor: 'int'
                └── VariableExpression: 'x'
                    └── Type
                        ├── category: 'basic'
                        └── descriptor: 'unsigned int'

@endtest

@test("An integer can be cast to unsigned (implicit int)")
@given("file")
int main() {
    int y;
    y = 42;
    unsigned x;
    x = (unsigned)y;
    return x;
}
@whenRun("./bin/cclynx", args="--emit-ast --no-warnings")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
└── FunctionDefinition: 'main' <unspecified-parameters>
    ├── ReturnType
    │   ├── category: 'basic'
    │   └── descriptor: 'int'
    └── CompoundStatement
        ├── VariableDeclaration: 'y'
        │   └── Type
        │       ├── category: 'basic'
        │       └── descriptor: 'int'
        ├── ExpressionStatement
        │   └── AssignmentExpression: '='
        │       ├── VariableExpression: 'y'
        │       │   └── Type
        │       │       ├── category: 'basic'
        │       │       └── descriptor: 'int'
        │       └── IntegerConstant: '42'
        │           └── Type
        │               ├── category: 'basic'
        │               └── descriptor: 'int'
        ├── VariableDeclaration: 'x'
        │   └── Type
        │       ├── category: 'basic'
        │       └── descriptor: 'unsigned int'
        ├── ExpressionStatement
        │   └── AssignmentExpression: '='
        │       ├── VariableExpression: 'x'
        │       │   └── Type
        │       │       ├── category: 'basic'
        │       │       └── descriptor: 'unsigned int'
        │       └── CastExpression
        │           ├── Type
        │           │   ├── category: 'basic'
        │           │   └── descriptor: 'unsigned int'
        │           └── VariableExpression: 'y'
        │               └── Type
        │                   ├── category: 'basic'
        │                   └── descriptor: 'int'
        └── ReturnStatement
            └── CastExpression
                ├── Type
                │   ├── category: 'basic'
                │   └── descriptor: 'int'
                └── VariableExpression: 'x'
                    └── Type
                        ├── category: 'basic'
                        └── descriptor: 'unsigned int'

@endtest
