@test("A float can be cast to an integer")
@given("file")
int main() {
    float y;
    y = 1.45;
    int x;
    x = (int)y;
    return x;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
└── FunctionDefinition: 'main' <unspecified-parameters>
    ├── ReturnType
    │   ├── category: 'basic'
    │   └── descriptor: 'int'
    └── CompoundStatement
        ├── VariableDeclaration: 'y'
        │   └── Type
        │       ├── category: 'basic'
        │       └── descriptor: 'float'
        ├── ExpressionStatement
        │   └── AssignmentExpression: '='
        │       ├── VariableExpression: 'y'
        │       │   └── Type
        │       │       ├── category: 'basic'
        │       │       └── descriptor: 'float'
        │       └── FloatConstant: '1.450000'
        │           └── Type
        │               ├── category: 'basic'
        │               └── descriptor: 'float'
        ├── VariableDeclaration: 'x'
        │   └── Type
        │       ├── category: 'basic'
        │       └── descriptor: 'int'
        ├── ExpressionStatement
        │   └── AssignmentExpression: '='
        │       ├── VariableExpression: 'x'
        │       │   └── Type
        │       │       ├── category: 'basic'
        │       │       └── descriptor: 'int'
        │       └── CastExpression
        │           ├── Type
        │           │   ├── category: 'basic'
        │           │   └── descriptor: 'int'
        │           └── VariableExpression: 'y'
        │               └── Type
        │                   ├── category: 'basic'
        │                   └── descriptor: 'float'
        └── ReturnStatement
            └── VariableExpression: 'x'
                └── Type
                    ├── category: 'basic'
                    └── descriptor: 'int'

@endtest

@test("An integer can be cast to a float")
@given("file")
float test() {
    int y;
    y = 777;
    float x;
    x = (float)y;
    return x;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
└── FunctionDefinition: 'test' <unspecified-parameters>
    ├── ReturnType
    │   ├── category: 'basic'
    │   └── descriptor: 'float'
    └── CompoundStatement
        ├── VariableDeclaration: 'y'
        │   └── Type
        │       ├── category: 'basic'
        │       └── descriptor: 'int'
        ├── ExpressionStatement
        │   └── AssignmentExpression: '='
        │       ├── VariableExpression: 'y'
        │       │   └── Type
        │       │       ├── category: 'basic'
        │       │       └── descriptor: 'int'
        │       └── IntegerConstant: '777'
        │           └── Type
        │               ├── category: 'basic'
        │               └── descriptor: 'int'
        ├── VariableDeclaration: 'x'
        │   └── Type
        │       ├── category: 'basic'
        │       └── descriptor: 'float'
        ├── ExpressionStatement
        │   └── AssignmentExpression: '='
        │       ├── VariableExpression: 'x'
        │       │   └── Type
        │       │       ├── category: 'basic'
        │       │       └── descriptor: 'float'
        │       └── CastExpression
        │           ├── Type
        │           │   ├── category: 'basic'
        │           │   └── descriptor: 'float'
        │           └── VariableExpression: 'y'
        │               └── Type
        │                   ├── category: 'basic'
        │                   └── descriptor: 'int'
        └── ReturnStatement
            └── VariableExpression: 'x'
                └── Type
                    ├── category: 'basic'
                    └── descriptor: 'float'

@endtest

@test("An integer can be cast to unsigned int")
@given("file")
int main() {
    int y;
    y = 42;
    unsigned int x;
    x = (unsigned int)y;
    return x;
}
@whenRun("./bin/cclynx", args="--emit-ast --no-warnings")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
└── FunctionDefinition: 'main' <unspecified-parameters>
    ├── ReturnType
    │   ├── category: 'basic'
    │   └── descriptor: 'int'
    └── CompoundStatement
        ├── VariableDeclaration: 'y'
        │   └── Type
        │       ├── category: 'basic'
        │       └── descriptor: 'int'
        ├── ExpressionStatement
        │   └── AssignmentExpression: '='
        │       ├── VariableExpression: 'y'
        │       │   └── Type
        │       │       ├── category: 'basic'
        │       │       └── descriptor: 'int'
        │       └── IntegerConstant: '42'
        │           └── Type
        │               ├── category: 'basic'
        │               └── descriptor: 'int'
        ├── VariableDeclaration: 'x'
        │   └── Type
        │       ├── category: 'basic'
        │       └── descriptor: 'unsigned int'
        ├── ExpressionStatement
        │   └── AssignmentExpression: '='
        │       ├── VariableExpression: 'x'
        │       │   └── Type
        │       │       ├── category: 'basic'
        │       │       └── descriptor: 'unsigned int'
        │       └── CastExpression
        │           ├── Type
        │           │   ├── category: 'basic'
        │           │   └── descriptor: 'unsigned int'
        │           └── VariableExpression: 'y'
        │               └── Type
        │                   ├── category: 'basic'
        │                   └── descriptor: 'int'
        └── ReturnStatement
            └── VariableExpression: 'x'
                └── Type
                    ├── category: 'basic'
                    └── descriptor: 'unsigned int'

@endtest

@test("An integer can be cast to unsigned (implicit int)")
@given("file")
int main() {
    int y;
    y = 42;
    unsigned x;
    x = (unsigned)y;
    return x;
}
@whenRun("./bin/cclynx", args="--emit-ast --no-warnings")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
└── FunctionDefinition: 'main' <unspecified-parameters>
