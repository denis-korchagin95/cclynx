@test("A float can be cast to an integer")
@given("file")
int main() {
    float y;
    y = 1.45;
    int x;
    x = (int)y;
    return x;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
|
+-> FunctionDefinition: 'main' {type: 'int'} <unspecified-parameters>
    |
    +-> CompoundStatement
        |
        +-> VariableDeclaration: 'y' {type: 'float'}
        |
        +-> ExpressionStatement
        |   |
        |   +-> AssignmentExpression: '='
        |       |
        |       +-> VariableExpression: 'y' {type: 'float'}
        |       |
        |       +-> FloatConstant: '1.450000' {type: 'float'}
        |
        +-> VariableDeclaration: 'x' {type: 'int'}
        |
        +-> ExpressionStatement
        |   |
        |   +-> AssignmentExpression: '='
        |       |
        |       +-> VariableExpression: 'x' {type: 'int'}
        |       |
        |       +-> CastExpression {type: 'int'}
        |           |
        |           +-> VariableExpression: 'y' {type: 'float'}
        |
        +-> ReturnStatement
            |
            +-> VariableExpression: 'x' {type: 'int'}

@endtest

@test("An integer can be cast to a float")
@given("file")
float test() {
    int y;
    y = 777;
    float x;
    x = (float)y;
    return x;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
|
+-> FunctionDefinition: 'test' {type: 'float'} <unspecified-parameters>
    |
    +-> CompoundStatement
        |
        +-> VariableDeclaration: 'y' {type: 'int'}
        |
        +-> ExpressionStatement
        |   |
        |   +-> AssignmentExpression: '='
        |       |
        |       +-> VariableExpression: 'y' {type: 'int'}
        |       |
        |       +-> IntegerConstant: '777' {type: 'int'}
        |
        +-> VariableDeclaration: 'x' {type: 'float'}
        |
        +-> ExpressionStatement
        |   |
        |   +-> AssignmentExpression: '='
        |       |
        |       +-> VariableExpression: 'x' {type: 'float'}
        |       |
        |       +-> CastExpression {type: 'float'}
        |           |
        |           +-> VariableExpression: 'y' {type: 'int'}
        |
        +-> ReturnStatement
            |
            +-> VariableExpression: 'x' {type: 'float'}

@endtest
