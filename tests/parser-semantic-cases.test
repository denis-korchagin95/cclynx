@test("It should raise an error on variable redeclaration")
@given("file")
int main() {
    int result;
    int result;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stderr")
ERROR: variable 'result' already declared!

@endtest

@test("It should raise an error when name of the variable is keyword")
@given("file")
int main() {
    int while;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stderr")
ERROR: expected identifier but not a keyword!

@endtest

@test("It should raise an error when trying to use undeclared variable")
@given("file")
int main() {
    int result;
    result = x + 1;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stderr")
ERROR: undeclared variable "x"!

@endtest

@test("It should raise an error when trying to use keyword as variable")
@given("file")
int main() {
    int result;
    result = int + 1;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stderr")
ERROR: expected identifier but not a keyword!

@endtest

@test("It should raise an error on function redefinition")
@given("file")
int foo() {
    return 1;
}

int foo() {
    return 2;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stderr")
ERROR: function 'foo' already defined!

@endtest

@test("It should raise an error when function name is a keyword")
@given("file")
int while() {
    return 1;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stderr")
ERROR: expected identifier but not a keyword!

@endtest

@test("It should allow the same variable name in two different function bodies")
@given("file")
int foo() {
    int x;
    x = 1;
    return x;
}

int bar() {
    int x;
    x = 2;
    return x;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
|
+-> FunctionDefinition: 'foo' {type: 'int'} <unspecified-parameters>
|   |
|   +-> CompoundStatement
|       |
|       +-> VariableDeclaration: 'x' {type: 'int'}
|       |
|       +-> ExpressionStatement
|       |   |
|       |   +-> AssignmentExpression: '='
|       |       |
|       |       +-> VariableExpression: 'x' {type: 'int'}
|       |       |
|       |       +-> IntegerConstant: '1' {type: 'int'}
|       |
|       +-> ReturnStatement
|           |
|           +-> VariableExpression: 'x' {type: 'int'}
|
+-> FunctionDefinition: 'bar' {type: 'int'} <unspecified-parameters>
    |
    +-> CompoundStatement
        |
        +-> VariableDeclaration: 'x' {type: 'int'}
        |
        +-> ExpressionStatement
        |   |
        |   +-> AssignmentExpression: '='
        |       |
        |       +-> VariableExpression: 'x' {type: 'int'}
        |       |
        |       +-> IntegerConstant: '2' {type: 'int'}
        |
        +-> ReturnStatement
            |
            +-> VariableExpression: 'x' {type: 'int'}

@endtest

@test("It should raise an error when variable is not visible outside its block")
@given("file")
int main() {
    int x;
    x = 1;
    {
        int y;
        y = 2;
    }
    x = y;
    return x;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stderr")
ERROR: undeclared variable "y"!

@endtest

@test("It should allow outer variable to be visible inside nested block")
@given("file")
int main() {
    int x;
    x = 1;
    {
        x = 2;
    }
    return x;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
|
+-> FunctionDefinition: 'main' {type: 'int'} <unspecified-parameters>
    |
    +-> CompoundStatement
        |
        +-> VariableDeclaration: 'x' {type: 'int'}
        |
        +-> ExpressionStatement
        |   |
        |   +-> AssignmentExpression: '='
        |       |
        |       +-> VariableExpression: 'x' {type: 'int'}
        |       |
        |       +-> IntegerConstant: '1' {type: 'int'}
        |
        +-> CompoundStatement
        |   |
        |   +-> ExpressionStatement
        |       |
        |       +-> AssignmentExpression: '='
        |           |
        |           +-> VariableExpression: 'x' {type: 'int'}
        |           |
        |           +-> IntegerConstant: '2' {type: 'int'}
        |
        +-> ReturnStatement
            |
            +-> VariableExpression: 'x' {type: 'int'}

@endtest

@test("It should raise an error on variable redeclaration in nested block")
@given("file")
int main() {
    {
        int y;
        int y;
    }
    return 0;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stderr")
ERROR: variable 'y' already declared!

@endtest

@test("It should raise an error when variable from sibling block is not visible")
@given("file")
int main() {
    {
        int y;
        y = 1;
    }
    {
        y = 2;
    }
    return 0;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stderr")
ERROR: undeclared variable "y"!

@endtest

@test("It should allow variable shadowing in nested block")
@given("file")
int main() {
    int x;
    x = 1;
    {
        int x;
        x = 2;
    }
    return x;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
|
+-> FunctionDefinition: 'main' {type: 'int'} <unspecified-parameters>
    |
    +-> CompoundStatement
        |
        +-> VariableDeclaration: 'x' {type: 'int'}
        |
        +-> ExpressionStatement
        |   |
        |   +-> AssignmentExpression: '='
        |       |
        |       +-> VariableExpression: 'x' {type: 'int'}
        |       |
        |       +-> IntegerConstant: '1' {type: 'int'}
        |
        +-> CompoundStatement
        |   |
        |   +-> VariableDeclaration: 'x' {type: 'int'}
        |   |
        |   +-> ExpressionStatement
        |       |
        |       +-> AssignmentExpression: '='
        |           |
        |           +-> VariableExpression: 'x' {type: 'int'}
        |           |
        |           +-> IntegerConstant: '2' {type: 'int'}
        |
        +-> ReturnStatement
            |
            +-> VariableExpression: 'x' {type: 'int'}

@endtest

@test("It should raise an error on mixed types in variable declaration")
@given("file")
int main() {
    float int x = 1;
    return 0;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stderr")
ERROR: mixed types!

@endtest

