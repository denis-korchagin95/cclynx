@test("It should parse source from a file")
@given("file")
int main() {
    return 42;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
└── FunctionDefinition: 'main' <unspecified-parameters>
    ├── ReturnType
    │   ├── category: 'basic'
    │   └── descriptor: 'int'
    └── CompoundStatement
        └── ReturnStatement
            └── IntegerConstant: '42'
                └── Type
                    ├── category: 'basic'
                    └── descriptor: 'int'

@endtest

@test("It should parse source from stdin via /dev/stdin")
@given("stdin")
int main() {
    return 42;
}
@whenRun("./bin/cclynx", args="--emit-ast /dev/stdin")
@expectOutput("stdout")
TranslationUnit: 'stdin'
└── FunctionDefinition: 'main' <unspecified-parameters>
    ├── ReturnType
    │   ├── category: 'basic'
    │   └── descriptor: 'int'
    └── CompoundStatement
        └── ReturnStatement
            └── IntegerConstant: '42'
                └── Type
                    ├── category: 'basic'
                    └── descriptor: 'int'

@endtest

