@test("It should parse main function with void argument list")
@given("file", filename="func_1.c")
int main(void) {
    return 42;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: 'func_1.c'
|
+-> FunctionDefinition: 'main' {type: 'int'} <no-parameters>
    |
    +-> CompoundStatement
        |
        +-> ReturnStatement
            |
            +-> IntegerConstant: '42' {type: 'int'}

@endtest

@test("It should parse main function (with basic expression)")
@given("file", filename="func_2.c")
int main() {
    7 * 8;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: 'func_2.c'
|
+-> FunctionDefinition: 'main' {type: 'int'} <unspecified-parameters>
    |
    +-> CompoundStatement
        |
        +-> ExpressionStatement
            |
            +-> MultiplicativeExpression: '*' {type: 'int'}
                |
                +-> IntegerConstant: '7' {type: 'int'}
                |
                +-> IntegerConstant: '8' {type: 'int'}

@endtest

@test("It should parse main function (with two variable declarations x and y)")
@given("file", filename="func_3.c")
int main() {
    int x;
    int y;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: 'func_3.c'
|
+-> FunctionDefinition: 'main' {type: 'int'} <unspecified-parameters>
    |
    +-> CompoundStatement
        |
        +-> VariableDeclaration: 'x' {type: 'int'}
        |
        +-> VariableDeclaration: 'y' {type: 'int'}

@endtest

@test("It should parse main function with return expression")
@given("file", filename="func_4.c")
int main() {
    return 7;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: 'func_4.c'
|
+-> FunctionDefinition: 'main' {type: 'int'} <unspecified-parameters>
    |
    +-> CompoundStatement
        |
        +-> ReturnStatement
            |
            +-> IntegerConstant: '7' {type: 'int'}

@endtest

@test("It should parse main function with return (empty expression)")
@given("file", filename="func_5.c")
int main() {
    return;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: 'func_5.c'
|
+-> FunctionDefinition: 'main' {type: 'int'} <unspecified-parameters>
    |
    +-> CompoundStatement
        |
        +-> ReturnStatement

@endtest

@test("It should parse main function with return variable")
@given("file", filename="func_6.c")
int main() {
    int result;
    result = 1;
    return result;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: 'func_6.c'
|
+-> FunctionDefinition: 'main' {type: 'int'} <unspecified-parameters>
    |
    +-> CompoundStatement
        |
        +-> VariableDeclaration: 'result' {type: 'int'}
        |
        +-> ExpressionStatement
        |   |
        |   +-> AssignmentExpression: '='
        |       |
        |       +-> Variable: 'result' {type: 'int'}
        |       |
        |       +-> IntegerConstant: '1' {type: 'int'}
        |
        +-> ReturnStatement
            |
            +-> Variable: 'result' {type: 'int'}

@endtest

@test("It should parse multiple function definitions")
@given("file", filename="func_7.c")
int foo() {
    return 1;
}

int bar() {
    return 2;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: 'func_7.c'
|
+-> FunctionDefinition: 'foo' {type: 'int'} <unspecified-parameters>
|   |
|   +-> CompoundStatement
|       |
|       +-> ReturnStatement
|           |
|           +-> IntegerConstant: '1' {type: 'int'}
|
+-> FunctionDefinition: 'bar' {type: 'int'} <unspecified-parameters>
    |
    +-> CompoundStatement
        |
        +-> ReturnStatement
            |
            +-> IntegerConstant: '2' {type: 'int'}

@endtest

@test("It should parse multiple functions with same variable names in different scopes")
@given("file", filename="func_8.c")
int foo() {
    int x;
    return x;
}

int bar() {
    int x;
    return x;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: 'func_8.c'
|
+-> FunctionDefinition: 'foo' {type: 'int'} <unspecified-parameters>
|   |
|   +-> CompoundStatement
|       |
|       +-> VariableDeclaration: 'x' {type: 'int'}
|       |
|       +-> ReturnStatement
|           |
|           +-> Variable: 'x' {type: 'int'}
|
+-> FunctionDefinition: 'bar' {type: 'int'} <unspecified-parameters>
    |
    +-> CompoundStatement
        |
        +-> VariableDeclaration: 'x' {type: 'int'}
        |
        +-> ReturnStatement
            |
            +-> Variable: 'x' {type: 'int'}

@endtest
