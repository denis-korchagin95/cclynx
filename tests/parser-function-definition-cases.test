@test("It should parse main function with void argument list")
@given("file")
int main(void) {
    return 42;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
|
+-> FunctionDefinition: 'main' {type: 'int'} <no-parameters>
    |
    +-> CompoundStatement
        |
        +-> ReturnStatement
            |
            +-> IntegerConstant: '42' {type: 'int'}

@endtest

@test("It should parse main function (with basic expression)")
@given("file")
int main() {
    7 * 8;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
|
+-> FunctionDefinition: 'main' {type: 'int'} <unspecified-parameters>
    |
    +-> CompoundStatement
        |
        +-> ExpressionStatement
            |
            +-> MultiplicativeExpression: '*' {type: 'int'}
                |
                +-> IntegerConstant: '7' {type: 'int'}
                |
                +-> IntegerConstant: '8' {type: 'int'}

@endtest

@test("It should parse main function (with two variable declarations x and y)")
@given("file")
int main() {
    int x;
    int y;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
|
+-> FunctionDefinition: 'main' {type: 'int'} <unspecified-parameters>
    |
    +-> CompoundStatement
        |
        +-> VariableDeclaration: 'x' {type: 'int'}
        |
        +-> VariableDeclaration: 'y' {type: 'int'}

@endtest

@test("It should parse main function with return expression")
@given("file")
int main() {
    return 7;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
|
+-> FunctionDefinition: 'main' {type: 'int'} <unspecified-parameters>
    |
    +-> CompoundStatement
        |
        +-> ReturnStatement
            |
            +-> IntegerConstant: '7' {type: 'int'}

@endtest

@test("It should parse main function with return (empty expression)")
@given("file")
int main() {
    return;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
|
+-> FunctionDefinition: 'main' {type: 'int'} <unspecified-parameters>
    |
    +-> CompoundStatement
        |
        +-> ReturnStatement

@endtest

@test("It should parse main function with return variable")
@given("file")
int main() {
    int result;
    result = 1;
    return result;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
|
+-> FunctionDefinition: 'main' {type: 'int'} <unspecified-parameters>
    |
    +-> CompoundStatement
        |
        +-> VariableDeclaration: 'result' {type: 'int'}
        |
        +-> ExpressionStatement
        |   |
        |   +-> AssignmentExpression: '='
        |       |
        |       +-> VariableExpression: 'result' {type: 'int'}
        |       |
        |       +-> IntegerConstant: '1' {type: 'int'}
        |
        +-> ReturnStatement
            |
            +-> VariableExpression: 'result' {type: 'int'}

@endtest

@test("It should parse multiple function definitions")
@given("file")
int foo() {
    return 1;
}

int bar() {
    return 2;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
|
+-> FunctionDefinition: 'foo' {type: 'int'} <unspecified-parameters>
|   |
|   +-> CompoundStatement
|       |
|       +-> ReturnStatement
|           |
|           +-> IntegerConstant: '1' {type: 'int'}
|
+-> FunctionDefinition: 'bar' {type: 'int'} <unspecified-parameters>
    |
    +-> CompoundStatement
        |
        +-> ReturnStatement
            |
            +-> IntegerConstant: '2' {type: 'int'}

@endtest

@test("It should parse multiple functions with same variable names in different scopes")
@given("file")
int foo() {
    int x;
    return x;
}

int bar() {
    int x;
    return x;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
|
+-> FunctionDefinition: 'foo' {type: 'int'} <unspecified-parameters>
|   |
|   +-> CompoundStatement
|       |
|       +-> VariableDeclaration: 'x' {type: 'int'}
|       |
|       +-> ReturnStatement
|           |
|           +-> VariableExpression: 'x' {type: 'int'}
|
+-> FunctionDefinition: 'bar' {type: 'int'} <unspecified-parameters>
    |
    +-> CompoundStatement
        |
        +-> VariableDeclaration: 'x' {type: 'int'}
        |
        +-> ReturnStatement
            |
            +-> VariableExpression: 'x' {type: 'int'}

@endtest

@test("It should parse function with 1 parameter")
@given("file")
int identity(int a) {
    return a;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
|
+-> FunctionDefinition: 'identity' {type: 'int'} <1-parameter>
    |
    +-> ParameterList
    |   |
    |   +-> Parameter: 'a' {type: 'int'}
    |
    +-> CompoundStatement
        |
        +-> ReturnStatement
            |
            +-> VariableExpression: 'a' {type: 'int'}

@endtest

@test("It should parse function with 2 parameters")
@given("file")
int add(int a, int b) {
    return a + b;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
|
+-> FunctionDefinition: 'add' {type: 'int'} <2-parameters>
    |
    +-> ParameterList
    |   |
    |   +-> Parameter: 'a' {type: 'int'}
    |   |
    |   +-> Parameter: 'b' {type: 'int'}
    |
    +-> CompoundStatement
        |
        +-> ReturnStatement
            |
            +-> AdditiveExpression: '+' {type: 'int'}
                |
                +-> VariableExpression: 'a' {type: 'int'}
                |
                +-> VariableExpression: 'b' {type: 'int'}

@endtest

@test("It should parse function with 3 parameters")
@given("file")
int foo(int a, int b, int c) {
    return a + b * c;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stdout")
TranslationUnit: '{{any}}'
|
+-> FunctionDefinition: 'foo' {type: 'int'} <3-parameters>
    |
    +-> ParameterList
    |   |
    |   +-> Parameter: 'a' {type: 'int'}
    |   |
    |   +-> Parameter: 'b' {type: 'int'}
    |   |
    |   +-> Parameter: 'c' {type: 'int'}
    |
    +-> CompoundStatement
        |
        +-> ReturnStatement
            |
            +-> AdditiveExpression: '+' {type: 'int'}
                |
                +-> VariableExpression: 'a' {type: 'int'}
                |
                +-> MultiplicativeExpression: '*' {type: 'int'}
                    |
                    +-> VariableExpression: 'b' {type: 'int'}
                    |
                    +-> VariableExpression: 'c' {type: 'int'}

@endtest

@test("It should raise an error when parameter type is not a type specifier")
@given("file")
int foo(bar a) {
    return a;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stderr")
{{any}}:1:9: ERROR: expected type specifier but got identifier 'bar'
{{any}}:1:9: ERROR: expected ')' but got identifier 'bar'

@endtest

@test("It should raise an error when parameter name is missing after type")
@given("file")
int foo(int) {
    return 0;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stderr")
{{any}}:1:12: ERROR: expected identifier but got ')'

@endtest

@test("It should raise an error when parameter name is a keyword")
@given("file")
int foo(int return) {
    return 0;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stderr")
{{any}}:1:13: ERROR: expected identifier but got keyword 'return'

@endtest

@test("It should raise an error when too many parameters")
@given("file")
int foo(int a, int b, int c, int d) {
    return 0;
}
@whenRun("./bin/cclynx", args="--emit-ast")
@expectOutput("stderr")
{{any}}:1:28: ERROR: too many parameters, maximum is 3

@endtest
